@page "/doctor/dashboard"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>SympNet — Dashboard Médecin</PageTitle>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Instrument Sans',sans-serif;background:#F0F9FF;min-height:100vh}
.app{display:flex;min-height:100vh}
.sidebar{width:260px;height:100vh;position:fixed;top:0;left:0;background:#fff;border-right:1px solid #BFDBFE;display:flex;flex-direction:column;z-index:100}
.sb-top{padding:20px 18px 14px;border-bottom:1px solid #BFDBFE}
.sb-brand{display:flex;align-items:center;gap:11px}
.sb-bic{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);display:flex;align-items:center;justify-content:center;font-size:18px}
.sb-bname{font-family:'Bricolage Grotesque',sans-serif;font-size:18px;font-weight:800;color:#0B2D2C}
.sb-bsub{font-size:9.5px;color:#93C5FD;margin-top:3px}
.sb-nav{flex:1;padding:12px 10px;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.nlbl{font-size:10px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;color:#93C5FD;padding:10px 10px 5px}
.nitem{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:10px;font-size:13.5px;font-weight:500;color:#64748B;cursor:pointer;transition:all .15s;text-decoration:none;position:relative}
.nitem:hover{background:#EFF6FF;color:#1D4ED8}
.nitem.active{background:linear-gradient(90deg,#EFF6FF,#DBEAFE);color:#1D4ED8;font-weight:600}
.nitem.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:18px;background:#3B82F6;border-radius:0 3px 3px 0}
.nitem svg{width:16px;height:16px;flex-shrink:0}
.sb-foot{padding:12px 14px;border-top:1px solid #BFDBFE;display:flex;align-items:center;gap:10px}
.sbav{width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff}
.sblo{width:30px;height:30px;border-radius:7px;color:#93C5FD;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;background:none;transition:all .15s}
.sblo:hover{background:#FEF2F2;color:#EF4444}.sblo svg{width:15px;height:15px}
.main{margin-left:260px;flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{height:66px;background:#fff;border-bottom:1px solid #BFDBFE;display:flex;align-items:center;justify-content:space-between;padding:0 26px;position:sticky;top:0;z-index:50}
.bcc{font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:700;color:#0B2D2C}
.role-tag{font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;background:#EFF6FF;color:#1D4ED8;text-transform:uppercase;letter-spacing:.5px}
.tbav{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:#fff}
.cnt{flex:1;padding:26px;overflow-y:auto}
.wb{border-radius:18px;padding:26px 30px;display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;background:linear-gradient(135deg,#1E3A8A,#1D4ED8 45%,#3B82F6);position:relative;overflow:hidden}
.wb::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 78% 50%,rgba(255,255,255,.06),transparent 60%)}
.wbt{position:relative;z-index:1}
.wbt h3{font-family:'Bricolage Grotesque',sans-serif;font-size:20px;font-weight:700;color:#fff;margin-bottom:5px}
.wbt p{font-size:13.5px;color:rgba(255,255,255,.6)}
.wbr{position:relative;z-index:1;text-align:right}
.wbday{font-family:'Bricolage Grotesque',sans-serif;font-size:34px;font-weight:800;color:#fff;line-height:1}
.wbinf{font-size:12px;color:rgba(255,255,255,.5);margin-top:4px}
.sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-bottom:22px}
.sc{background:#fff;border:1px solid #BFDBFE;border-radius:14px;padding:18px;box-shadow:0 1px 3px rgba(30,64,175,.06);display:flex;flex-direction:column;gap:11px}
.sc:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(30,64,175,.1);transition:all .2s}
.sct{display:flex;align-items:flex-start;justify-content:space-between}
.sic{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sic svg{width:19px;height:19px}
.sic.b{background:#EFF6FF;color:#1D4ED8}.sic.g{background:#F0FDF4;color:#22C55E}.sic.t{background:#F0FBFA;color:#0D6E6A}
.sv{font-family:'Bricolage Grotesque',sans-serif;font-size:28px;font-weight:800;color:#0B2D2C;letter-spacing:-1px;line-height:1}
.sl{font-size:12.5px;color:#93C5FD;margin-top:3px}
.card{background:#fff;border:1px solid #BFDBFE;border-radius:14px;box-shadow:0 1px 3px rgba(30,64,175,.06);overflow:hidden;margin-bottom:16px}
.chd{padding:16px 18px;border-bottom:1px solid #BFDBFE;display:flex;align-items:center;justify-content:space-between}
.chd h3{font-family:'Bricolage Grotesque',sans-serif;font-size:14px;font-weight:700;color:#0B2D2C}
.coming-soon{padding:40px;text-align:center}
.coming-soon .icon{font-size:40px;margin-bottom:12px}
.coming-soon h4{font-size:15px;font-weight:600;color:#64748B;margin-bottom:6px}
.coming-soon p{font-size:13px;color:#93C5FD}
.badge{display:inline-block;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:600;background:#FEF3C7;color:#D97706}
</style>

<div class="app">
  <aside class="sidebar">
    <div class="sb-top">
      <div class="sb-brand">
        <div class="sb-bic">🩺</div>
        <div><div class="sb-bname">SympNet</div><div class="sb-bsub">Doctor Portal</div></div>
      </div>
    </div>
    <nav class="sb-nav">
      <div class="nlbl">Vue Générale</div>
      <a class="nitem active" href="/doctor/dashboard?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"/><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"/></svg>
        Tableau de bord
      </a>
      <div class="nlbl">Clinique</div>
      <a class="nitem" href="/doctor/patients?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
        Mes Patients
      </a>
      <a class="nitem" href="/doctor/appointments?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
        Rendez-vous
      </a>
      <div class="nlbl">Compte</div>
      <a class="nitem" href="/doctor/profile?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
        Mon Profil
      </a>
    </nav>
    <div class="sb-foot">
      <div class="sbav">@(userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "D")</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:12.5px;font-weight:600;color:#0B2D2C;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">Dr. @userEmail</div>
        <div style="font-size:11px;color:#93C5FD;margin-top:2px">Médecin</div>
      </div>
      <button class="sblo" @onclick="Logout">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <div class="bcc">Tableau de bord</div>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="role-tag">MÉDECIN</span>
        <div class="tbav">@(userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "D")</div>
      </div>
    </header>
    <div class="cnt">
      <div class="wb">
        <div class="wbt">
          <h3>Bonjour, Dr. @userEmail 👋</h3>
          <p>Voici votre tableau de bord clinique du @DateTime.Now.ToString("dddd dd MMMM", new System.Globalization.CultureInfo("fr-FR")).</p>
        </div>
        <div class="wbr">
          <div class="wbday">@DateTime.Now.Day</div>
          <div class="wbinf">@DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</div>
        </div>
      </div>
      <div class="sgrid">
        <div class="sc">
          <div class="sct"><div class="sic b"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg></div><span class="badge">Sprint 2</span></div>
          <div><div class="sv">—</div><div class="sl">Mes Patients</div></div>
        </div>
        <div class="sc">
          <div class="sct"><div class="sic g"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg></div><span class="badge">Sprint 2</span></div>
          <div><div class="sv">—</div><div class="sl">Rendez-vous</div></div>
        </div>
        <div class="sc">
          <div class="sct"><div class="sic t"><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"/></svg></div><span class="badge">Sprint 3</span></div>
          <div><div class="sv">—</div><div class="sl">Consultations IA</div></div>
        </div>
      </div>
      <div class="card">
        <div class="chd"><h3>📋 Activité récente</h3></div>
        <div class="coming-soon">
          <div class="icon">🚧</div>
          <h4>Fonctionnalité en développement</h4>
          <p>L'historique des consultations sera disponible au Sprint 2</p>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    private string userEmail = "";
    protected override void OnInitialized() => userEmail = Email ?? "";
    private void Logout() => Nav.NavigateTo("/login");
}