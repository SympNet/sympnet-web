@page "/profile"
@layout MainLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>SympNet — Mon Profil</PageTitle>

<style>
    :root {
        --primary: #0D9488;
        --success: #10B981;
        --gray: #6B7280;
        --white: #FFFFFF;
        --light: #F9FAFB;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --radius-lg: 16px;
        --radius-xl: 24px;
    }

    .profile-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .profile-card {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .profile-header {
        background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
        padding: 48px 40px;
    }

    .profile-avatar-container {
        display: flex;
        align-items: center;
        gap: 32px;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: 800;
        color: white;
        border: 3px solid rgba(255, 255, 255, 0.3);
    }

    .profile-info h2 {
        font-size: 28px;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
    }

    .profile-info p {
        font-size: 14px;
        color: rgba(255, 255, 255, 0.8);
    }

    .profile-body {
        padding: 32px 40px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 32px;
    }

    .info-card {
        background: var(--light);
        border-radius: var(--radius-lg);
        padding: 24px;
    }

    .info-card h3 {
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        color: #1F2937;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-size: 13px;
        color: var(--gray);
    }

    .info-value {
        font-size: 14px;
        font-weight: 600;
        color: #1F2937;
    }

    .status-active {
        color: var(--success);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 20px;
        text-align: center;
        border: 1px solid rgba(13, 148, 136, 0.1);
    }

    .stat-value {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 12px;
        color: var(--gray);
    }

    .activity-timeline {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 24px;
        border: 1px solid rgba(13, 148, 136, 0.1);
    }

    .timeline-item {
        display: flex;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .timeline-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(13, 148, 136, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0D9488;
    }

    .timeline-title {
        font-weight: 600;
        margin-bottom: 4px;
    }

    .timeline-date {
        font-size: 11px;
        color: var(--gray);
    }

    @@media (max-width: 1024px) {
        .info-grid { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="profile-container">
    @if (isLoading)
    {
        <div style="text-align: center; padding: 60px;">
            <div style="width: 50px; height: 50px; border: 3px solid rgba(13,148,136,0.1); border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
            <p>Chargement de votre profil...</p>
        </div>
    }
    else
    {
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar-container">
                    <div class="profile-avatar">@(userRole == "admin" ? "A" : (userName.Length > 0 ? userName[0].ToString().ToUpper() : "D"))</div>
                    <div class="profile-info">
                        <h2>@(userRole == "admin" ? "Administrateur" : $"Dr. {userName}")</h2>
                        <p><i class="fas fa-envelope"></i> @userEmail</p>
                    </div>
                </div>
            </div>

            <div class="profile-body">
                <div class="info-grid">
                    <div class="info-card">
                        <h3><i class="fas fa-user-circle"></i> Informations du Compte</h3>
                        <div class="info-row">
                            <span class="info-label">Email</span>
                            <span class="info-value">@userEmail</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Rôle</span>
                            <span class="info-value">@(userRole == "admin" ? "Administrateur" : "Médecin")</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">Statut</span>
                            <span class="info-value status-active">✓ Actif</span>
                        </div>
                    </div>

                    @if (userRole != "admin")
                    {
                        <div class="info-card">
                            <h3><i class="fas fa-stethoscope"></i> Informations Professionnelles</h3>
                            <div class="info-row">
                                <span class="info-label">Spécialité</span>
                                <span class="info-value">@(doctorInfo?.Speciality ?? "Médecine Générale")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Licence</span>
                                <span class="info-value">@(doctorInfo?.LicenseNumber ?? "MED-2024-001")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Cabinet</span>
                                <span class="info-value">@(doctorInfo?.Address ?? "Tunis, Tunisie")</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="info-card">
                            <h3><i class="fas fa-chart-bar"></i> Statistiques Plateforme</h3>
                            <div class="info-row">
                                <span class="info-label">Total Médecins</span>
                                <span class="info-value">@stats.TotalDoctors</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">Médecins Actifs</span>
                                <span class="info-value">@stats.ActiveDoctors</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">En attente</span>
                                <span class="info-value">@stats.PendingDoctors</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-value">@(userRole == "admin" ? stats.TotalDoctors : "128")</div><div class="stat-label">@(userRole == "admin" ? "Médecins" : "Patients traités")</div></div>
                    <div class="stat-card"><div class="stat-value">@(userRole == "admin" ? "85%" : "94%")</div><div class="stat-label">Taux d'activité</div></div>
                    <div class="stat-card"><div class="stat-value">@(userRole == "admin" ? "24h" : "2.5h")</div><div class="stat-label">Temps de réponse</div></div>
                    <div class="stat-card"><div class="stat-value">@(userRole == "admin" ? "156" : "42")</div><div class="stat-label">Analyses IA</div></div>
                </div>

                <div class="activity-timeline">
                    <h3 style="margin-bottom: 20px;"><i class="fas fa-history"></i> Activité récente</h3>
                    @foreach (var activity in activities)
                    {
                        <div class="timeline-item">
                            <div class="timeline-icon"><i class="fas @activity.Icon"></i></div>
                            <div class="timeline-content">
                                <div class="timeline-title">@activity.Title</div>
                                <div class="timeline-date">@activity.Date.ToString("dd MMMM yyyy, HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Role { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }

    private string userRole = "";
    private string userEmail = "";
    private string userName = "";
    private bool isLoading = true;
    private DoctorInfoDto? doctorInfo = null;
    private StatsDto stats = new();
    private List<ActivityDto> activities = new();

    protected override async Task OnInitializedAsync()
    {
        userEmail = Email ?? "";
        userRole = (Role ?? "").ToLower();
        userName = userEmail.Split('@')[0];

        if (!string.IsNullOrEmpty(Token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        }

        await LoadProfileData();
        isLoading = false;
    }

    private async Task LoadProfileData()
    {
        try
        {
            if (userRole == "admin")
            {
                var s = await Http.GetFromJsonAsync<StatsDto>("api/admin/stats");
                if (s != null) stats = s;
            }
            else
            {
                var docs = await Http.GetFromJsonAsync<List<DoctorInfoDto>>("api/admin/doctors");
                doctorInfo = docs?.FirstOrDefault(d => d.Email == userEmail);
                if (doctorInfo != null) userName = $"{doctorInfo.FirstName} {doctorInfo.LastName}";
            }

            activities = new List<ActivityDto>
            {
                new() { Title = "Connexion à la plateforme", Date = DateTime.Now.AddHours(-2), Icon = "fa-sign-in-alt" },
                new() { Title = "Consultation de profil", Date = DateTime.Now.AddHours(-1), Icon = "fa-eye" },
                new() { Title = "Mise à jour des préférences", Date = DateTime.Now.AddDays(-2), Icon = "fa-cog" }
            };
        }
        catch { }
    }

    public class DoctorInfoDto
    {
        public int Id { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Speciality { get; set; } = "";
        public string LicenseNumber { get; set; } = "";
        public string Address { get; set; } = "";
        public double AverageRating { get; set; }
        public string Email { get; set; } = "";
    }

    public class StatsDto
    {
        public int TotalPatients { get; set; }
        public int TotalDoctors { get; set; }
        public int ActiveDoctors { get; set; }
        public int PendingDoctors { get; set; }
    }

    public class ActivityDto
    {
        public string Title { get; set; } = "";
        public DateTime Date { get; set; }
        public string Icon { get; set; } = "";
    }
}