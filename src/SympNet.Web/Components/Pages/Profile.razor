@page "/profile"
@using SympNet.Web.Components.Layout
@layout AdminLayout
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using System.Text.Json

<PageTitle>SympNet — Mon Profil</PageTitle>

<style>
    .profile-container { max-width: 1200px; margin: 0 auto; }
    .profile-card { background: white; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
    .profile-header { background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); padding: 48px 40px; position: relative; }
    .avatar-wrapper { position: relative; cursor: pointer; display: inline-block; }
    .profile-avatar { width: 100px; height: 100px; background: rgba(255,255,255,0.2); border-radius: 24px; display: flex; align-items: center; justify-content: center; font-size: 40px; font-weight: 800; color: white; object-fit: cover; }
    .avatar-overlay { position: absolute; bottom: 0; right: 0; background: white; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: #0D9488; cursor: pointer; border: 2px solid white; }
    .profile-info h2 { font-size: 28px; font-weight: 800; color: white; margin-bottom: 8px; }
    .edit-badge { background: rgba(255,255,255,0.2); padding: 4px 12px; border-radius: 100px; font-size: 12px; margin-top: 8px; display: inline-block; cursor: pointer; }
    .profile-body { padding: 32px 40px; }
    .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-bottom: 32px; }
    .info-card { background: #F9FAFB; border-radius: 16px; padding: 24px; }
    .info-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 20px; }
    .info-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 6px; color: #374151; }
    .form-group input { width: 100%; padding: 10px 12px; border: 1.5px solid #E5E7EB; border-radius: 10px; font-size: 14px; }
    .btn-save { background: #0D9488; color: white; padding: 8px 20px; border-radius: 10px; border: none; cursor: pointer; margin-right: 10px; }
    .btn-cancel { background: #F3F4F6; color: #6B7280; padding: 8px 20px; border-radius: 10px; border: none; cursor: pointer; }
    .alert-success { background: #D1FAE5; color: #065F46; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #10B981; }
    .alert-error { background: #FEE2E2; color: #991B1B; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #EF4444; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 16px; padding: 20px; text-align: center; border: 1px solid rgba(13,148,136,0.1); }
    .stat-value { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
    .timeline-item { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid rgba(0,0,0,0.05); }
    .file-input-hidden { display: none; }
</style>

<div class="profile-container">
    @if (isLoading) 
    {
        <div style="text-align: center; padding: 60px;">
            <div style="width: 50px; height: 50px; border: 3px solid rgba(13,148,136,0.1); border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite;"></div>
            <p>Chargement...</p>
        </div>
    }
    else
    {
        <div class="profile-card">
            <div class="profile-header">
                <div class="avatar-wrapper" @onclick="TriggerFileUpload">
                    @if (!string.IsNullOrEmpty(profileImage))
                    {
                        <img src="@profileImage" class="profile-avatar" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="profile-avatar">A</div>
                    }
                    <div class="avatar-overlay"><i class="fas fa-camera"></i></div>
                </div>
                <div class="profile-info">
                    <h2>@(isEditing ? "Modifier le profil" : "Administrateur")</h2>
                    <p>@userEmail</p>
                    <div class="edit-badge" @onclick="ToggleEdit">
                        <i class="fas fa-@(isEditing ? "times" : "pen")"></i> @(isEditing ? "Annuler" : "Modifier le profil")
                    </div>
                </div>
            </div>
            <div class="profile-body">
                @if (!string.IsNullOrEmpty(successMessage)) 
                { 
                    <div class="alert-success">@successMessage</div> 
                }
                @if (!string.IsNullOrEmpty(errorMessage)) 
                { 
                    <div class="alert-error">@errorMessage</div> 
                }

                @if (isEditing)
                {
                    <div class="info-card" style="margin-bottom: 24px;">
                        <h3>Modifier les informations</h3>
                        <div class="form-group">
                            <label>Nom d'utilisateur</label>
                            <input type="text" @bind="adminName" @bind:event="oninput" />
                        </div>
                        <div class="form-group">
                            <label>Téléphone</label>
                            <input type="tel" @bind="adminPhone" @bind:event="oninput" />
                        </div>
                        <div style="margin-top: 20px;">
                            <button class="btn-save" @onclick="SaveProfile" disabled="@isSaving">@(isSaving ? "Enregistrement..." : "Enregistrer")</button>
                            <button class="btn-cancel" @onclick="CancelEdit">Annuler</button>
                        </div>
                    </div>
                }

                <div class="info-grid">
                    <div class="info-card">
                        <h3>Informations du Compte</h3>
                        <div class="info-row"><span>Email</span><span>@userEmail</span></div>
                        <div class="info-row"><span>Nom</span><span>@adminName</span></div>
                        <div class="info-row"><span>Téléphone</span><span>@adminPhone</span></div>
                        <div class="info-row"><span>Rôle</span><span>Administrateur</span></div>
                        <div class="info-row"><span>Statut</span><span style="color:#10B981;">✓ Actif</span></div>
                    </div>
                    <div class="info-card">
                        <h3>Statistiques Plateforme</h3>
                        <div class="info-row"><span>Total Médecins</span><span>@stats.TotalDoctors</span></div>
                        <div class="info-row"><span>Médecins Actifs</span><span>@stats.ActiveDoctors</span></div>
                        <div class="info-row"><span>En attente</span><span>@stats.PendingDoctors</span></div>
                        <div class="info-row"><span>Total Patients</span><span>@stats.TotalPatients</span></div>
                    </div>
                </div>

                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-value">@stats.TotalDoctors</div><div>Médecins</div></div>
                    <div class="stat-card"><div class="stat-value">@stats.TotalPatients</div><div>Patients</div></div>
                    <div class="stat-card"><div class="stat-value">85%</div><div>Taux d'activité</div></div>
                    <div class="stat-card"><div class="stat-value">156</div><div>Analyses IA</div></div>
                </div>
                
                <div class="activity-timeline">
                    <h3>Activité récente</h3>
                    @foreach (var a in activities) 
                    {
                        <div class="timeline-item">
                            <div><i class="fas @a.Icon"></i></div>
                            <div>
                                <div>@a.Title</div>
                                <div>@a.Date.ToString("dd MMMM yyyy, HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    <InputFile id="avatarFileInput" class="file-input-hidden" OnChange="HandleImageUpload" accept="image/*" />
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    
    private string userEmail = "";
    private string adminName = "";
    private string adminPhone = "";
    private string profileImage = "";
    private bool isLoading = true;
    private bool isEditing = false;
    private bool isSaving = false;
    private string successMessage = "";
    private string errorMessage = "";
    private StatsDto stats = new();
    private List<ActivityDto> activities = new();

    protected override async Task OnInitializedAsync()
    {
        userEmail = Email ?? "";
        adminName = userEmail.Split('@')[0];
        adminPhone = "+216 99 999 999";
        
        if (!string.IsNullOrEmpty(Token)) 
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        }
        
        await LoadProfileData();
        isLoading = false;
    }

    private void ToggleEdit()
    {
        if (isEditing)
        {
            CancelEdit();
        }
        else
        {
            isEditing = true;
        }
    }

    private async Task TriggerFileUpload()
    {
        // Utiliser JS pour déclencher le click sur l'input file
        await JS.InvokeVoidAsync("eval", @"
            var input = document.getElementById('avatarFileInput');
            if (input) {
                input.click();
            } else {
                console.error('Input file not found');
            }
        ");
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file != null && file.Size < 2 * 1024 * 1024)
            {
                var buffer = new byte[file.Size];
                await using var stream = file.OpenReadStream();
                var bytesRead = await stream.ReadAsync(buffer);
                var base64 = Convert.ToBase64String(buffer);
                var extension = Path.GetExtension(file.Name).ToLower();
                var mimeType = extension switch
                {
                    ".png" => "image/png",
                    ".jpg" or ".jpeg" => "image/jpeg",
                    ".gif" => "image/gif",
                    _ => "image/jpeg"
                };
                profileImage = $"data:{mimeType};base64,{base64}";
                successMessage = "Photo mise à jour !";
                await ClearMessages();
                StateHasChanged();
            }
            else 
            { 
                errorMessage = "Fichier trop volumineux (max 2MB)"; 
                await ClearMessages();
            }
        }
        catch (Exception ex)
        { 
            errorMessage = "Erreur lors du téléchargement: " + ex.Message; 
            await ClearMessages();
        }
    }

    private async Task SaveProfile()
    {
        isSaving = true;
        StateHasChanged();
        try
        {
            // Appel API pour sauvegarder
            await Task.Delay(500);
            successMessage = "Profil mis à jour !";
            isEditing = false;
            await ClearMessages();
        }
        catch 
        { 
            errorMessage = "Erreur lors de la sauvegarde"; 
            await ClearMessages();
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void CancelEdit()
    {
        isEditing = false;
        adminName = userEmail.Split('@')[0];
        adminPhone = "+216 99 999 999";
        StateHasChanged();
    }

    private async Task LoadProfileData()
    {
        try 
        { 
            var s = await Http.GetFromJsonAsync<StatsDto>("api/admin/stats"); 
            if (s != null) stats = s; 
            activities = new List<ActivityDto>
            { 
                new() { Title = "Connexion", Date = DateTime.Now.AddHours(-2), Icon = "fa-sign-in-alt" }, 
                new() { Title = "Dashboard consulté", Date = DateTime.Now.AddHours(-1), Icon = "fa-chart-line" } 
            }; 
        } 
        catch { }
    }

    private async Task ClearMessages() 
    { 
        await Task.Delay(3000); 
        successMessage = ""; 
        errorMessage = ""; 
        StateHasChanged();
    }

    public class StatsDto 
    { 
        public int TotalPatients { get; set; } 
        public int TotalDoctors { get; set; } 
        public int ActiveDoctors { get; set; } 
        public int PendingDoctors { get; set; } 
    }
    
    public class ActivityDto 
    { 
        public string Title { get; set; } = ""; 
        public DateTime Date { get; set; } 
        public string Icon { get; set; } = ""; 
    }
}