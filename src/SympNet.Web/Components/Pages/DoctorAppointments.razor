@page "/doctor/appointments"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>SympNet — Rendez-vous</PageTitle>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Instrument Sans',sans-serif;background:#F0F9FF;min-height:100vh}
.app{display:flex;min-height:100vh}
.sidebar{width:260px;height:100vh;position:fixed;top:0;left:0;background:#fff;border-right:1px solid #BFDBFE;display:flex;flex-direction:column;z-index:100}
.sb-top{padding:20px 18px 14px;border-bottom:1px solid #BFDBFE}
.sb-brand{display:flex;align-items:center;gap:11px}
.sb-bic{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);display:flex;align-items:center;justify-content:center;font-size:18px}
.sb-bname{font-family:'Bricolage Grotesque',sans-serif;font-size:18px;font-weight:800;color:#0B2D2C}
.sb-bsub{font-size:9.5px;color:#93C5FD;margin-top:3px}
.sb-nav{flex:1;padding:12px 10px;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.nlbl{font-size:10px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;color:#93C5FD;padding:10px 10px 5px}
.nitem{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:10px;font-size:13.5px;font-weight:500;color:#64748B;cursor:pointer;transition:all .15s;text-decoration:none;position:relative}
.nitem:hover{background:#EFF6FF;color:#1D4ED8}
.nitem.active{background:linear-gradient(90deg,#EFF6FF,#DBEAFE);color:#1D4ED8;font-weight:600}
.nitem.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:18px;background:#3B82F6;border-radius:0 3px 3px 0}
.nitem svg{width:16px;height:16px;flex-shrink:0}
.sb-foot{padding:12px 14px;border-top:1px solid #BFDBFE;display:flex;align-items:center;gap:10px}
.sbav{width:34px;height:34px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff}
.sblo{width:30px;height:30px;border-radius:7px;color:#93C5FD;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;background:none}
.sblo:hover{background:#FEF2F2;color:#EF4444}.sblo svg{width:15px;height:15px}
.main{margin-left:260px;flex:1;display:flex;flex-direction:column}
.topbar{height:66px;background:#fff;border-bottom:1px solid #BFDBFE;display:flex;align-items:center;justify-content:space-between;padding:0 26px;position:sticky;top:0}
.bcc{font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:700;color:#0B2D2C}
.role-tag{font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;background:#EFF6FF;color:#1D4ED8;text-transform:uppercase}
.cnt{flex:1;padding:26px}
.ph{margin-bottom:26px}
.ph h1{font-family:'Bricolage Grotesque',sans-serif;font-size:26px;font-weight:800;color:#0B2D2C;margin-bottom:5px}
.ph p{font-size:13.5px;color:#93C5FD}
.coming{background:#fff;border:1px solid #BFDBFE;border-radius:18px;padding:60px;text-align:center}
.coming .icon{font-size:56px;margin-bottom:16px}
.coming h3{font-family:'Bricolage Grotesque',sans-serif;font-size:22px;font-weight:800;color:#0B2D2C;margin-bottom:8px}
.coming p{font-size:14px;color:#93C5FD;max-width:400px;margin:0 auto 24px}
.badge-sprint{display:inline-block;padding:6px 16px;border-radius:999px;background:#DBEAFE;color:#1D4ED8;font-size:13px;font-weight:600}
</style>

<div class="app">
  <aside class="sidebar">
    <div class="sb-top">
      <div class="sb-brand">
        <div class="sb-bic">🩺</div>
        <div><div class="sb-bname">SympNet</div><div class="sb-bsub">Doctor Portal</div></div>
      </div>
    </div>
    <nav class="sb-nav">
      <div class="nlbl">Vue Générale</div>
      <a class="nitem" href="/doctor/dashboard?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"/></svg>
        Tableau de bord
      </a>
      <div class="nlbl">Clinique</div>
      <a class="nitem" href="/doctor/patients?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
        Mes Patients
      </a>
      <a class="nitem active" href="/doctor/appointments?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
        Rendez-vous
      </a>
      <div class="nlbl">Compte</div>
      <a class="nitem" href="/doctor/profile?token=@Token&email=@Email">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
        Mon Profil
      </a>
    </nav>
    <div class="sb-foot">
      <div class="sbav">@(userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "D")</div>
      <div style="flex:1;min-width:0">
        <div style="font-size:12.5px;font-weight:600;color:#0B2D2C">Dr. @userEmail</div>
        <div style="font-size:11px;color:#93C5FD;margin-top:2px">Médecin</div>
      </div>
      <button class="sblo" @onclick="Logout">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </aside>
  <div class="main">
    <header class="topbar">
      <div class="bcc">Rendez-vous</div>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="role-tag">MÉDECIN</span>
        <div style="width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,#1E40AF,#3B82F6);display:flex;align-items:center;justify-content:center;font-weight:700;color:#fff">@(userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "D")</div>
      </div>
    </header>
    <div class="cnt">
      <div class="ph">
        <h1>📅 Rendez-vous</h1>
        <p>Gérez vos consultations et planifiez vos rendez-vous</p>
      </div>
      <div class="coming">
        <div class="icon">📅</div>
        <h3>Gestion des Rendez-vous</h3>
        <p>Le calendrier des rendez-vous et la gestion des consultations seront disponibles au Sprint 2.</p>
        <span class="badge-sprint">🚀 Sprint 2 — En développement</span>
      </div>
    </div>
  </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    private string userEmail = "";
    protected override void OnInitialized() => userEmail = Email ?? "";
    private void Logout() => Nav.NavigateTo("/login");
}