@page "/reset-password"
@inject HttpClient Http
@inject NavigationManager Navigation

<style>
    .reset-password-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #084E4B, #1A9E97);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .reset-password-card {
        background: white;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 400px;
    }
    
    .reset-password-card h2 {
        color: #084E4B;
        margin-bottom: 1.5rem;
        text-align: center;
    }
    
    .form-group {
        margin-bottom: 1rem;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        color: #5E8584;
        font-weight: 500;
    }
    
    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #DFF0EF;
        border-radius: 8px;
        font-size: 1rem;
    }
    
    .form-control:focus {
        outline: none;
        border-color: #1A9E97;
        box-shadow: 0 0 0 2px rgba(26,158,151,0.2);
    }
    
    .btn {
        width: 100%;
        padding: 0.75rem;
        background: linear-gradient(135deg, #0D6E6A, #3ABFB8);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 1rem;
        transition: opacity 0.3s;
    }
    
    .btn:hover {
        opacity: 0.9;
    }
    
    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    
    .alert {
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }
    
    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    
    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    
    .spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
        margin-right: 8px;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<PageTitle>Réinitialisation du mot de passe - SympNet</PageTitle>

<div class="reset-password-container">
    <div class="reset-password-card">
        <h2>🔐 Réinitialisation du mot de passe</h2>
        
        @if (isValidating)
        {
            <div style="text-align: center; padding: 2rem;">
                <div class="spinner" style="width: 40px; height: 40px; border-width: 3px;"></div>
                <p style="margin-top: 1rem; color: #5E8584;">Vérification du lien...</p>
            </div>
        }
        else if (IsValidUrl)
        {
            @if (!IsSuccess)
            {
                <form @onsubmit="HandleResetPassword">
                    <div class="form-group">
                        <label>📧 Email</label>
                        <input type="email" @bind="Email" class="form-control" disabled />
                    </div>
                    
                    <div class="form-group">
                        <label>🔑 Nouveau mot de passe</label>
                        <input type="password" @bind="NewPassword" class="form-control" placeholder="Au moins 6 caractères" required />
                    </div>
                    
                    <div class="form-group">
                        <label>✓ Confirmer le mot de passe</label>
                        <input type="password" @bind="ConfirmPassword" class="form-control" placeholder="Répétez le mot de passe" required />
                    </div>
                    
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger">
                            ⚠️ @ErrorMessage
                        </div>
                    }
                    
                    <button type="submit" class="btn" disabled="@IsLoading">
                        @if (IsLoading)
                        {
                            <span class="spinner"></span>
                        }
                        @(IsLoading ? "Chargement..." : "✅ Réinitialiser le mot de passe")
                    </button>
                </form>
            }
            else
            {
                <div class="alert alert-success">
                    <p style="text-align:center; margin-bottom:1rem;">✅ Votre mot de passe a été réinitialisé avec succès !</p>
                    <button @onclick="GoToLogin" class="btn" style="margin-top:0;">🔑 Se connecter</button>
                </div>
            }
        }
        else
        {
            <div class="alert alert-danger">
                <p style="text-align:center; margin-bottom:1rem;">❌ Lien de réinitialisation invalide ou expiré.</p>
                <button @onclick="GoToLogin" class="btn" style="margin-top:0;">🏠 Retour à la connexion</button>
            </div>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? token { get; set; }
    
    [SupplyParameterFromQuery]
    private string? email { get; set; }
    
    private string NewPassword = "";
    private string ConfirmPassword = "";
    private string ErrorMessage = "";
    private bool IsLoading = false;
    private bool IsSuccess = false;
    private bool IsValidUrl = false;
    private bool isValidating = true;
    private string Email = "";
    
    // DTO local
    private class ResetPasswordRequest
    {
        public string Token { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
    }
    
    protected override async Task OnInitializedAsync()
    {
        await ValidateUrl();
    }
    
    private async Task ValidateUrl()
    {
        isValidating = true;
        StateHasChanged();
        
        // Vérifier que token et email sont présents
        IsValidUrl = !string.IsNullOrEmpty(token) && !string.IsNullOrEmpty(email);
        Email = email ?? "";
        
        if (IsValidUrl)
        {
            // Optionnel : faire une requête pour vérifier si le token est valide
            // avant d'afficher le formulaire
            try
            {
                var response = await Http.PostAsJsonAsync("api/auth/validate-reset-token", 
                    new { Token = token, Email = email });
                
                if (!response.IsSuccessStatusCode)
                {
                    IsValidUrl = false;
                }
            }
            catch
            {
                // Si l'API n'est pas accessible, on laisse passer quand même
                // car l'erreur sera capturée lors de la tentative de reset
            }
        }
        
        isValidating = false;
        StateHasChanged();
    }
    
    private async Task HandleResetPassword()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(NewPassword))
        {
            ErrorMessage = "Veuillez saisir un mot de passe.";
            return;
        }
        
        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Les mots de passe ne correspondent pas.";
            return;
        }
        
        if (NewPassword.Length < 6)
        {
            ErrorMessage = "Le mot de passe doit contenir au moins 6 caractères.";
            return;
        }
        
        IsLoading = true;
        ErrorMessage = "";
        StateHasChanged();
        
        try
        {
            var request = new ResetPasswordRequest
            {
                Token = token!,
                NewPassword = NewPassword
            };
            
            var response = await Http.PostAsJsonAsync("api/auth/reset-password", request);
            
            if (response.IsSuccessStatusCode)
            {
                IsSuccess = true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                ErrorMessage = error?.message ?? $"Erreur lors de la réinitialisation. Status: {response.StatusCode}";
            }
        }
        catch (HttpRequestException ex)
        {
            ErrorMessage = $"Impossible de contacter le serveur. Vérifiez que l'API est démarrée sur le port 5237. ({ex.Message})";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
    
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
    
    private class ErrorResponse
    {
        public string? message { get; set; }
    }
}