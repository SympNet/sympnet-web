@page "/admin/doctors"
@layout EmptyLayout

<PageTitle>SympNet — Gestion des Médecins</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>

<style>
:root{
  --b:#3ABFB8;--bd:#1A9E97;--bdd:#0D6E6A;--bddd:#084E4B;--bl:#6DD4CE;
  --bp:#E6F8F7;--bm:#F0FBFA;--w:#fff;--off:#F4FAFA;
  --bor:#DFF0EF;--bor2:#C5E8E7;
  --ink:#0B2D2C;--inm:#2E5554;--ind:#5E8584;--inf:#9DBDBC;
  --gr:#22C55E;--grb:#F0FDF4;--am:#F59E0B;--amb:#FFFBEB;
  --re:#EF4444;--reb:#FEF2F2;--bl2:#3B82F6;--blb:#EFF6FF;
  --pu:#8B5CF6;--pub:#F5F3FF;
  --sw:260px;--bh:66px;
  --s0:0 1px 2px rgba(10,80,78,.05);--s1:0 2px 8px rgba(10,80,78,.09);
  --s2:0 6px 24px rgba(10,80,78,.12);--s3:0 16px 48px rgba(10,80,78,.16);--s4:0 28px 72px rgba(10,80,78,.2);
  --ea:cubic-bezier(.22,1,.36,1);--sp:cubic-bezier(.34,1.56,.64,1);
  --fh:'Bricolage Grotesque',sans-serif;--fb:'Instrument Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--off);color:var(--ink);min-height:100vh;-webkit-font-smoothing:antialiased}
button{cursor:pointer;font-family:var(--fb);border:none;background:none}
input,select{font-family:var(--fb);outline:none}

/* ── LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:var(--sw);height:100vh;position:fixed;top:0;left:0;z-index:100;background:var(--w);border-right:1px solid var(--bor);display:flex;flex-direction:column;transition:transform .3s var(--ea)}
.sb-top{padding:20px 18px 14px;border-bottom:1px solid var(--bor)}
.sb-brand{display:flex;align-items:center;gap:11px}
.sb-bic{width:36px;height:36px;border-radius:9px;flex-shrink:0;background:linear-gradient(135deg,var(--bdd),var(--b));display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(26,158,151,.25)}
.sb-bname{font-family:var(--fh);font-size:18px;font-weight:800;color:var(--ink);letter-spacing:-.4px;line-height:1}
.sb-bsub{font-size:9.5px;color:var(--inf);margin-top:3px}
.sb-nav{flex:1;padding:12px 10px;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.nlbl{font-size:10px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;color:var(--inf);padding:10px 10px 5px;margin-top:4px}.nlbl:first-child{margin-top:0}
.nitem{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:10px;font-size:13.5px;font-weight:500;color:var(--ind);cursor:pointer;transition:all .15s;position:relative;text-decoration:none}
.nitem:hover{background:var(--bm);color:var(--bd)}
.nitem.active{background:linear-gradient(90deg,var(--bp),var(--bm));color:var(--bdd);font-weight:600}
.nitem.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:18px;background:var(--b);border-radius:0 3px 3px 0}
.nitem svg{width:16px;height:16px;flex-shrink:0}
.npill{margin-left:auto;color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:999px;line-height:1.5;background:var(--b)}
.sb-foot{padding:12px 14px;border-top:1px solid var(--bor);display:flex;align-items:center;gap:10px}
.sbav{width:34px;height:34px;border-radius:9px;flex-shrink:0;background:linear-gradient(135deg,var(--bdd),var(--b));display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:13px;font-weight:700;color:#fff}
.sbu{flex:1;min-width:0}
.sbun{font-size:12.5px;font-weight:600;color:var(--ink)}
.sbur{font-size:11px;color:var(--inf);margin-top:2px}
.sblo{width:30px;height:30px;border-radius:7px;color:var(--inf);display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0}
.sblo:hover{background:var(--reb);color:var(--re)}.sblo svg{width:15px;height:15px}

/* ── MAIN ── */
.main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{height:var(--bh);background:var(--w);border-bottom:1px solid var(--bor);display:flex;align-items:center;justify-content:space-between;padding:0 26px;position:sticky;top:0;z-index:50}
.tbl{display:flex;align-items:center;gap:12px}
.bc{display:flex;align-items:center;gap:7px}
.bcr{font-size:13px;color:var(--inf)}.bcs{font-size:13px;color:var(--inf)}
.bcc{font-family:var(--fh);font-size:16px;font-weight:700;color:var(--ink);letter-spacing:-.3px}
.tbr-right{display:flex;align-items:center;gap:9px}
.sbox{display:flex;align-items:center;gap:8px;background:var(--bm);border:1.5px solid var(--bor);border-radius:10px;padding:0 13px;height:36px;transition:border-color .18s;width:240px}
.sbox:focus-within{border-color:var(--b)}.sbox svg{width:14px;height:14px;color:var(--inf);flex-shrink:0}
.sbox input{border:none;background:none;font-size:13px;color:var(--ink);width:100%}
.sbox input::placeholder{color:var(--inf)}
.role-tag{font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;letter-spacing:.5px;text-transform:uppercase;background:var(--bp);color:var(--bdd)}
.tbav-top{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--bdd),var(--b));display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:15px;font-weight:700;color:#fff}

/* ── PAGE CONTENT ── */
.cnt{flex:1;padding:26px;animation:si .28s var(--ea) both}
@@keyframes si{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}

/* ── PAGE HEADER ── */
.ph{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:26px;gap:16px;flex-wrap:wrap}
.ph-left h1{font-family:var(--fh);font-size:26px;font-weight:800;color:var(--ink);letter-spacing:-.6px;margin-bottom:5px}
.ph-left p{font-size:13.5px;color:var(--inf)}
.ph-actions{display:flex;align-items:center;gap:10px}
.badd{display:inline-flex;align-items:center;gap:7px;padding:10px 18px;background:linear-gradient(135deg,var(--bdd),var(--b));color:#fff;border-radius:10px;font-size:13.5px;font-weight:600;border:none;cursor:pointer;box-shadow:0 4px 14px rgba(26,158,151,.25);transition:all .2s var(--ea)}
.badd:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(26,158,151,.35)}
.badd svg{width:15px;height:15px}

/* ── SUMMARY CARDS ── */
.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px}
.scard{background:var(--w);border:1px solid var(--bor);border-radius:14px;padding:18px 20px;display:flex;align-items:center;gap:14px;box-shadow:var(--s0);transition:all .2s var(--ea)}
.scard:hover{transform:translateY(-2px);box-shadow:var(--s2)}
.scard-ic{width:46px;height:46px;border-radius:12px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.scard-ic svg{width:21px;height:21px}
.scard-ic.t{background:rgba(58,191,184,.1);color:var(--bd)}
.scard-ic.g{background:var(--grb);color:var(--gr)}
.scard-ic.a{background:var(--amb);color:var(--am)}
.scard-val{font-family:var(--fh);font-size:30px;font-weight:800;color:var(--ink);letter-spacing:-1px;line-height:1}
.scard-lbl{font-size:12.5px;color:var(--inf);margin-top:3px}

/* ── FILTER BAR ── */
.fbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap}
.fbar-left{display:flex;align-items:center;gap:10px}
.clbl{font-size:13.5px;color:var(--inf)}.clbl b{color:var(--ink)}
.fstrip{display:flex;gap:3px;background:var(--w);border:1.5px solid var(--bor);border-radius:10px;padding:3px}
.fchip{padding:6px 14px;border-radius:7px;font-size:12.5px;font-weight:600;color:var(--ind);transition:all .16s;cursor:pointer;border:none;font-family:var(--fb)}
.fchip.act{background:var(--bdd);color:#fff}
.fchip:hover:not(.act){background:var(--bm)}

/* ── TABLE ── */
.tsh{background:var(--w);border:1px solid var(--bor);border-radius:14px;box-shadow:var(--s0);overflow:hidden}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--bm)}
th{padding:11px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--inf);border-bottom:1.5px solid var(--bor);white-space:nowrap}
tbody tr{border-bottom:1px solid var(--bor);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--bm)}
td{padding:13px 16px;font-size:13.5px;color:var(--inm);vertical-align:middle}
.dc{display:flex;align-items:center;gap:11px}
.dav{width:38px;height:38px;border-radius:10px;flex-shrink:0;background:linear-gradient(135deg,var(--bdd),var(--b));display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:14px;font-weight:700;color:#fff}
.dnm{font-size:13.5px;font-weight:600;color:var(--ink)}.dem{font-size:11.5px;color:var(--inf);margin-top:2px}
.stag{display:inline-block;padding:4px 10px;border-radius:999px;font-size:11.5px;font-weight:600;background:var(--bp);color:var(--bdd)}
.rtg{display:flex;align-items:center;gap:4px;font-size:13px;font-weight:600}
.str{color:#F59E0B}
.pill{font-size:11px;font-weight:600;padding:4px 10px;border-radius:999px;flex-shrink:0}
.pill.on{background:var(--grb);color:var(--gr)}.pill.off{background:var(--amb);color:var(--am)}

/* ── ACTION BUTTONS ── */
.ac{display:flex;align-items:center;gap:6px}

/* Activate button */
.btn-act{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;font-size:12px;font-weight:600;border:1.5px solid var(--grb);background:var(--grb);color:var(--gr);cursor:pointer;transition:all .15s}
.btn-act:hover{background:var(--gr);color:#fff;border-color:var(--gr)}
.btn-act svg{width:13px;height:13px}

/* Deactivate button */
.btn-dea{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:8px;font-size:12px;font-weight:600;border:1.5px solid var(--amb);background:var(--amb);color:var(--am);cursor:pointer;transition:all .15s}
.btn-dea:hover{background:var(--am);color:#fff;border-color:var(--am)}
.btn-dea svg{width:13px;height:13px}

/* Delete button */
.btn-del{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;color:var(--inf);cursor:pointer;transition:all .14s;border:none;background:none}
.btn-del:hover{background:var(--reb);color:var(--re)}
.btn-del svg{width:14px;height:14px}

/* ── EMPTY STATE ── */
.emp{text-align:center;padding:60px 20px}
.empic{font-size:46px;margin-bottom:12px}
.emp h4{font-size:15px;font-weight:600;color:var(--ind);margin-bottom:6px}
.emp p{font-size:13px;color:var(--inf)}

/* ── STATUS BANNER ── */
.status-banner{border-radius:12px;padding:13px 18px;display:flex;align-items:center;gap:12px;margin-bottom:16px;animation:si .3s var(--ea)}
.status-banner.active-banner{background:linear-gradient(135deg,var(--bm),var(--bp));border:1px solid var(--bor2)}
.status-banner.inactive-banner{background:linear-gradient(135deg,var(--amb),#FEF9EE);border:1px solid #FCD34D}
.sb-ico{font-size:20px}
.sb-txt{flex:1}
.sb-txt strong{display:block;font-size:13px;font-weight:700;color:var(--ink);margin-bottom:2px}
.sb-txt span{font-size:12px;color:var(--ind)}
.sb-cnt{font-family:var(--fh);font-size:24px;font-weight:800;color:var(--bdd)}

/* ── ADD FORM ── */
.add-panel{background:var(--w);border:1px solid var(--bor);border-radius:18px;box-shadow:var(--s1);max-width:680px;overflow:hidden;margin-top:0}
.add-panel-hd{padding:20px 24px;border-bottom:1px solid var(--bor);display:flex;align-items:center;gap:14px}
.add-panel-ic{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--bdd),var(--b));display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px rgba(26,158,151,.25)}
.add-panel-ic svg{width:20px;height:20px;color:#fff}
.add-panel-hd h3{font-family:var(--fh);font-size:16px;font-weight:800;color:var(--ink);letter-spacing:-.3px}
.add-panel-hd p{font-size:12.5px;color:var(--inf);margin-top:3px}
.add-panel-body{padding:24px}
.fl{font-size:10.5px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--inf);margin-bottom:13px}
.fgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.ff label{display:block;font-size:12.5px;font-weight:600;color:var(--inm);margin-bottom:6px}
.ff input,.ff select{width:100%;padding:10px 13px;border:1.5px solid var(--bor2);border-radius:9px;font-size:13.5px;color:var(--ink);background:var(--w);transition:border-color .18s,box-shadow .18s;font-family:var(--fb)}
.ff input:focus,.ff select:focus{border-color:var(--b);box-shadow:0 0 0 3px rgba(58,191,184,.12)}
.ff input::placeholder{color:var(--inf)}
.facs{display:flex;align-items:center;justify-content:flex-end;gap:10px;margin-top:22px;padding-top:20px;border-top:1px solid var(--bor)}
.bcan{padding:9px 16px;border:1.5px solid var(--bor2);border-radius:9px;font-size:13px;font-weight:600;color:var(--ind);transition:all .15s}
.bcan:hover{border-color:var(--b);color:var(--bd)}
.bsub{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;background:linear-gradient(135deg,var(--bdd),var(--b));color:#fff;border-radius:9px;font-size:13px;font-weight:600;border:none;cursor:pointer;box-shadow:0 4px 12px rgba(26,158,151,.25);transition:all .2s}
.bsub:hover{transform:translateY(-1px);box-shadow:0 7px 18px rgba(26,158,151,.35)}

/* ── TOAST ── */
.toast{position:fixed;bottom:22px;right:22px;z-index:9999;color:#fff;padding:13px 17px;border-radius:14px;box-shadow:var(--s3);font-size:13.5px;font-weight:500;display:flex;align-items:center;gap:9px;opacity:0;transform:translateY(14px) scale(.95);pointer-events:none;transition:all .3s var(--sp);max-width:340px}
.toast.show{opacity:1;transform:translateY(0) scale(1);pointer-events:auto}
.toast.ok{background:linear-gradient(135deg,var(--bdd),var(--b))}.toast.er{background:linear-gradient(135deg,#7F1D1D,var(--re))}
.toast-ic{font-size:17px;flex-shrink:0}

/* ── MODAL ── */
.mbg{position:fixed;inset:0;z-index:999;background:rgba(8,30,30,.55);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .22s}
.mbg.show{opacity:1;pointer-events:auto}
.mbox{background:var(--w);border-radius:20px;padding:32px;max-width:380px;width:90%;text-align:center;box-shadow:var(--s4);transform:scale(.92) translateY(12px);transition:transform .3s var(--sp)}
.mbg.show .mbox{transform:scale(1) translateY(0)}
.mem{font-size:44px;margin-bottom:16px}

/* Modal types */
.mbox.confirm-activate .mheader{color:var(--bdd)}
.mbox.confirm-deactivate .mheader{color:var(--am)}
.mbox.confirm-delete .mheader{color:var(--re)}

.mheader{font-family:var(--fh);font-size:19px;font-weight:800;color:var(--ink);margin-bottom:8px;letter-spacing:-.4px}
.msub{font-size:13.5px;color:var(--ind);line-height:1.65;margin-bottom:24px}
.macs{display:flex;gap:10px}
.mcan{flex:1;padding:11px;border:1.5px solid var(--bor2);border-radius:10px;font-size:13.5px;font-weight:600;color:var(--ind);transition:all .15s;cursor:pointer}
.mcan:hover{border-color:var(--b);color:var(--bd)}
.mcnf{flex:1;padding:11px;border-radius:10px;font-size:13.5px;font-weight:700;color:#fff;cursor:pointer;transition:all .15s;border:none}
.mcnf.c-act{background:linear-gradient(135deg,var(--bdd),var(--b))}
.mcnf.c-dea{background:linear-gradient(135deg,#D97706,var(--am))}
.mcnf.c-del{background:linear-gradient(135deg,#7F1D1D,var(--re))}
.mcnf:hover{transform:translateY(-1px);filter:brightness(1.05)}

/* ── INLINE TOGGLE (switch) ── */
.tgl{position:relative;width:38px;height:22px;flex-shrink:0}
.tgl input{opacity:0;width:0;height:0;position:absolute}
.tslider{position:absolute;inset:0;border-radius:999px;cursor:pointer;transition:all .25s;background:#D1D5DB}
.tslider::before{content:'';position:absolute;width:16px;height:16px;border-radius:50%;background:#fff;top:3px;left:3px;transition:all .25s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.tgl input:checked + .tslider{background:var(--b)}
.tgl input:checked + .tslider::before{transform:translateX(16px)}

@@media(max-width:1080px){.summary{grid-template-columns:1fr 1fr}}
@@media(max-width:820px){.sidebar{transform:translateX(-100%)}.main{margin-left:0}.summary{grid-template-columns:1fr}}
@@media(max-width:580px){.cnt{padding:14px}.topbar{padding:0 14px}.fgrid{grid-template-columns:1fr}}
</style>

<div class="app">
  <!-- ═══ SIDEBAR ═══ -->
  <aside class="sidebar" id="sidebar">
    <div class="sb-top">
      <div class="sb-brand">
        <div class="sb-bic">
          <svg width="20" height="20" viewBox="0 0 26 26" fill="none">
            <line x1="13" y1="2" x2="13" y2="24" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M13 7C9.5 5 6 6.5 6 9.5C6 12.5 9.5 12.5 13 11" stroke="white" stroke-width="1.4" stroke-linecap="round" fill="none"/>
            <path d="M13 7C16.5 5 20 6.5 20 9.5C20 12.5 16.5 12.5 13 11" stroke="white" stroke-width="1.4" stroke-linecap="round" fill="none"/>
            <path d="M13 10C10 11.5 10 14.5 13 15.5C10 16.5 10 19.5 13 21" stroke="rgba(255,255,255,.8)" stroke-width="1.3" stroke-linecap="round" fill="none"/>
            <path d="M13 10C16 11.5 16 14.5 13 15.5C16 16.5 16 19.5 13 21" stroke="rgba(255,255,255,.8)" stroke-width="1.3" stroke-linecap="round" fill="none"/>
            <circle cx="13" cy="23" r="1.8" fill="rgba(255,255,255,.7)"/>
          </svg>
        </div>
        <div><div class="sb-bname">SympNet</div><div class="sb-bsub">Admin Portal</div></div>
      </div>
    </div>
    <nav class="sb-nav">
      <div class="nlbl">Vue Générale</div>
      <a class="nitem" href="/dashboard">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"/><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"/></svg>
        Tableau de bord
      </a>
      <div class="nlbl">Gestion</div>
      <a class="nitem active" href="/admin/doctors">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
        Médecins<span class="npill" id="npill">0</span>
      </a>
      <a class="nitem" href="/admin/doctors/add">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
        Ajouter Médecin
      </a>
      <div class="nlbl">Analytiques</div>
      <a class="nitem" href="/dashboard#stats">
        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zm6-4a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zm6-3a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"/></svg>
        Statistiques
      </a>
    </nav>
    <div class="sb-foot">
      <div class="sbav">A</div>
      <div class="sbu"><div class="sbun" id="sbun">Administrateur</div><div class="sbur" id="sbur">admin@sympnet.com</div></div>
      <button class="sblo" onclick="logout()" title="Déconnexion">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z" clip-rule="evenodd"/></svg>
      </button>
    </div>
  </aside>

  <!-- ═══ MAIN ═══ -->
  <div class="main">
    <header class="topbar">
      <div class="tbl">
        <div class="bc">
          <span class="bcr">SympNet</span>
          <span class="bcs"> / </span>
          <span class="bcr">Gestion</span>
          <span class="bcs"> / </span>
          <span class="bcc">Médecins</span>
        </div>
      </div>
      <div class="tbr-right">
        <div class="sbox">
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"/></svg>
          <input type="text" id="search-inp" placeholder="Rechercher par nom, email, spécialité…" oninput="onSearch(this.value)"/>
        </div>
        <span class="role-tag">ADMIN</span>
        <div class="tbav-top">A</div>
      </div>
    </header>

    <div class="cnt">

      <!-- PAGE HEADER -->
      <div class="ph">
        <div class="ph-left">
          <h1>Gestion des Médecins</h1>
          <p>Activez ou désactivez l'accès des médecins à la plateforme SympNet</p>
        </div>
        <div class="ph-actions">
          <button class="badd" onclick="showAddForm()">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
            Ajouter un Médecin
          </button>
        </div>
      </div>

      <!-- SUMMARY CARDS -->
      <div class="summary">
        <div class="scard">
          <div class="scard-ic t">
            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"/></svg>
          </div>
          <div><div class="scard-val" id="c-total">0</div><div class="scard-lbl">Total Médecins</div></div>
        </div>
        <div class="scard">
          <div class="scard-ic g">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          </div>
          <div><div class="scard-val" id="c-active">0</div><div class="scard-lbl">Médecins Actifs</div></div>
        </div>
        <div class="scard">
          <div class="scard-ic a">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524L13.477 14.89zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/></svg>
          </div>
          <div><div class="scard-val" id="c-inactive">0</div><div class="scard-lbl">Médecins Inactifs</div></div>
        </div>
      </div>

      <!-- ADD FORM (hidden by default) -->
      <div id="add-form-panel" class="add-panel" style="display:none;margin-bottom:24px">
        <div class="add-panel-hd">
          <div class="add-panel-ic">
            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z"/></svg>
          </div>
          <div>
            <h3>Nouveau Médecin</h3>
            <p>Les identifiants seront envoyés automatiquement par email</p>
          </div>
        </div>
        <div class="add-panel-body">
          <form id="dform" onsubmit="submitDoc(event)">
            <div class="fl">Informations Personnelles</div>
            <div class="fgrid" style="margin-bottom:16px">
              <div class="ff"><label>Prénom *</label><input id="ffn" type="text" placeholder="Ahmed" required/></div>
              <div class="ff"><label>Nom *</label><input id="fln" type="text" placeholder="Ben Ali" required/></div>
              <div class="ff"><label>Email *</label><input id="fem2" type="email" placeholder="doctor@gmail.com" required/></div>
              <div class="ff"><label>Téléphone</label><input id="fph" type="tel" placeholder="+216 XX XXX XXX"/></div>
            </div>
            <div class="fl">Informations Professionnelles</div>
            <div class="fgrid">
              <div class="ff"><label>Spécialité *</label>
                <select id="fsp" required>
                  <option value="">— Sélectionner —</option>
                  <option>Cardiologie</option><option>Dermatologie</option><option>Neurologie</option>
                  <option>Pédiatrie</option><option>Orthopédie</option><option>Ophtalmologie</option>
                  <option>Psychiatrie</option><option>Gynécologie</option><option>Médecine Générale</option>
                  <option>Urgentologie</option><option>Radiologie</option>
                </select>
              </div>
              <div class="ff"><label>Numéro Licence *</label><input id="fli" type="text" placeholder="MED-2026-001" required/></div>
              <div class="ff" style="grid-column:1/-1"><label>Adresse</label><input id="fad" type="text" placeholder="Tunis, Tunisie"/></div>
            </div>
            <div class="facs">
              <button type="button" class="bcan" onclick="hideAddForm()">Annuler</button>
              <button type="submit" class="bsub">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884zM18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
                Créer &amp; Envoyer Identifiants
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- FILTER BAR -->
      <div class="fbar">
        <div class="fbar-left">
          <div class="clbl">Affichage de <b id="dcnt">0</b> médecins</div>
          <div class="fstrip">
            <button class="fchip act" onclick="filterD('all',this)">Tous</button>
            <button class="fchip" onclick="filterD('active',this)">Actifs</button>
            <button class="fchip" onclick="filterD('inactive',this)">Inactifs</button>
          </div>
        </div>
      </div>

      <!-- TABLE -->
      <div class="tsh">
        <table>
          <thead>
            <tr>
              <th>Médecin</th>
              <th>Spécialité</th>
              <th>Numéro Licence</th>
              <th>Localisation</th>
              <th>Note</th>
              <th>Accès Plateforme</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="dtbody"></tbody>
        </table>
        <div id="temp-emp" class="emp" style="display:none">
          <div class="empic">🩺</div>
          <h4>Aucun médecin trouvé</h4>
          <p>Ajustez les filtres ou ajoutez de nouveaux médecins</p>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">
  <span class="toast-ic" id="toast-ic"></span>
  <span id="toast-msg"></span>
</div>

<!-- MODAL -->
<div class="mbg" id="mbg" onclick="closeModal()">
  <div class="mbox" id="mbox" onclick="event.stopPropagation()">
    <div class="mem" id="m-em">⚠️</div>
    <div class="mheader" id="m-hdr">Confirmer</div>
    <div class="msub" id="m-sub">Êtes-vous sûr ?</div>
    <div class="macs">
      <button class="mcan" onclick="closeModal()">Annuler</button>
      <button class="mcnf" id="m-cnf" onclick="confirmAction()">Confirmer</button>
    </div>
  </div>
</div>

<script>
// ── STATE ──────────────────────────────────────────────────────────────────
let docs = [
  {id:1,fn:'Ahmed',  ln:'Ben Ali',   sp:'Cardiologie',     lic:'MED-2026-001',addr:'Tunis',  rat:4.7, on:true,  em:'ahmed.benali@gmail.com'},
  {id:2,fn:'Sonia',  ln:'Gharsalli', sp:'Neurologie',      lic:'MED-2026-002',addr:'Sousse', rat:4.9, on:true,  em:'sonia.g@gmail.com'},
  {id:3,fn:'Karim',  ln:'Mansouri',  sp:'Pédiatrie',       lic:'MED-2026-003',addr:'Sfax',   rat:4.5, on:false, em:'karim.m@gmail.com'},
  {id:4,fn:'Yasmine',ln:'Ouertani',  sp:'Dermatologie',    lic:'MED-2026-004',addr:'Tunis',  rat:4.8, on:true,  em:'yasmine.o@gmail.com'},
  {id:5,fn:'Sirine', ln:'Rezgui',    sp:'Médecine Générale',lic:'MED-2026-005',addr:'Nabeul', rat:4.6, on:true,  em:'sirine.r@gmail.com'},
  {id:6,fn:'Bilel',  ln:'Hamrouni',  sp:'Cardiologie',     lic:'MED-2026-006',addr:'Bizerte',rat:4.3, on:false, em:'bilel.h@gmail.com'},
  {id:7,fn:'Mariem', ln:'Saidi',     sp:'Ophtalmologie',   lic:'MED-2026-007',addr:'Tunis',  rat:4.7, on:true,  em:'mariem.s@gmail.com'},
];
let nid = 8, fm = 'all', sq = '', pendingAction = null;

// ── INIT ────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const email = sessionStorage.getItem('sympnet_email') || 'admin@sympnet.com';
  document.getElementById('sbur').textContent = email;
  render();
});

// ── RENDER ──────────────────────────────────────────────────────────────────
function render() {
  // Update summary counts
  const tot = docs.length;
  const act = docs.filter(d => d.on).length;
  const ina = tot - act;
  document.getElementById('c-total').textContent = tot;
  document.getElementById('c-active').textContent = act;
  document.getElementById('c-inactive').textContent = ina;
  document.getElementById('npill').textContent = tot;

  // Filter list
  let list = [...docs];
  if (fm === 'active') list = list.filter(d => d.on);
  if (fm === 'inactive') list = list.filter(d => !d.on);
  if (sq) list = list.filter(d =>
    (d.fn + ' ' + d.ln + ' ' + d.sp + ' ' + d.em + ' ' + d.lic)
    .toLowerCase().includes(sq.toLowerCase())
  );
  document.getElementById('dcnt').textContent = list.length;

  const tb = document.getElementById('dtbody');
  const emp = document.getElementById('temp-emp');

  if (!list.length) {
    tb.innerHTML = '';
    emp.style.display = 'block';
    return;
  }
  emp.style.display = 'none';

  tb.innerHTML = list.map(d => `
    <tr id="row-${d.id}">
      <td>
        <div class="dc">
          <div class="dav">${d.fn[0]}${d.ln[0]}</div>
          <div>
            <div class="dnm">Dr. ${d.fn} ${d.ln}</div>
            <div class="dem">${d.em}</div>
          </div>
        </div>
      </td>
      <td><span class="stag">${d.sp}</span></td>
      <td style="font-size:12px;color:var(--inf);font-family:monospace">${d.lic}</td>
      <td style="font-size:13px">${d.addr}</td>
      <td>
        <div class="rtg">
          <span class="str">★</span>
          ${d.rat > 0 ? d.rat.toFixed(1) : '<span style="color:var(--inf);font-size:12px">—</span>'}
        </div>
      </td>
      <td>
        <!-- Toggle switch + status label -->
        <div style="display:flex;align-items:center;gap:10px">
          <label class="tgl" title="${d.on ? 'Désactiver' : 'Activer'}">
            <input type="checkbox" ${d.on ? 'checked' : ''} onchange="handleToggle(${d.id}, this.checked)"/>
            <span class="tslider"></span>
          </label>
          <span class="pill ${d.on ? 'on' : 'off'}" id="status-pill-${d.id}">${d.on ? 'Actif' : 'Inactif'}</span>
        </div>
      </td>
      <td>
        <div class="ac">
          ${d.on
            ? `<button class="btn-dea" onclick="confirmToggle(${d.id}, false)" title="Désactiver l'accès">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524L13.477 14.89zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/></svg>
                Désactiver
               </button>`
            : `<button class="btn-act" onclick="confirmToggle(${d.id}, true)" title="Activer l'accès">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Activer
               </button>`}
          <button class="btn-del" onclick="confirmDelete(${d.id})" title="Supprimer">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          </button>
        </div>
      </td>
    </tr>
  `).join('');
}

// ── TOGGLE VIA SWITCH (immediate, no modal) ────────────────────────────────
function handleToggle(id, on) {
  const d = docs.find(x => x.id === id);
  if (!d) return;
  d.on = on;
  render();
  toast(on ? '✅' : '🔒', `Dr. ${d.fn} ${d.ln} ${on ? 'activé' : 'désactivé'} avec succès.`, 'ok');
}

// ── TOGGLE VIA BUTTON (with confirmation modal) ────────────────────────────
function confirmToggle(id, on) {
  const d = docs.find(x => x.id === id);
  if (!d) return;
  const mbox = document.getElementById('mbox');
  document.getElementById('m-em').textContent = on ? '✅' : '⚠️';
  document.getElementById('m-hdr').textContent = on ? 'Activer le Médecin' : 'Désactiver le Médecin';
  document.getElementById('m-sub').textContent = on
    ? `Activer l'accès de Dr. ${d.fn} ${d.ln} à la plateforme SympNet ?\nIl pourra se connecter et accéder à ses patients.`
    : `Désactiver l'accès de Dr. ${d.fn} ${d.ln} ?\nIl ne pourra plus se connecter jusqu'à réactivation.`;
  const cnf = document.getElementById('m-cnf');
  cnf.textContent = on ? 'Activer' : 'Désactiver';
  cnf.className = `mcnf ${on ? 'c-act' : 'c-dea'}`;
  mbox.className = `mbox ${on ? 'confirm-activate' : 'confirm-deactivate'}`;
  pendingAction = () => {
    d.on = on;
    render();
    toast(on ? '✅' : '🔒', `Dr. ${d.fn} ${d.ln} ${on ? 'activé' : 'désactivé'} avec succès.`, 'ok');
  };
  openModal();
}

// ── DELETE ─────────────────────────────────────────────────────────────────
function confirmDelete(id) {
  const d = docs.find(x => x.id === id);
  if (!d) return;
  document.getElementById('m-em').textContent = '🗑️';
  document.getElementById('m-hdr').textContent = 'Supprimer le Médecin';
  document.getElementById('m-sub').textContent = `Supprimer définitivement Dr. ${d.fn} ${d.ln} de la plateforme ?\nCette action est irréversible.`;
  const cnf = document.getElementById('m-cnf');
  cnf.textContent = 'Supprimer';
  cnf.className = 'mcnf c-del';
  document.getElementById('mbox').className = 'mbox confirm-delete';
  pendingAction = () => {
    docs = docs.filter(x => x.id !== id);
    render();
    toast('🗑️', `Dr. ${d.fn} ${d.ln} supprimé définitivement.`, 'er');
  };
  openModal();
}

// ── ADD DOCTOR ─────────────────────────────────────────────────────────────
function showAddForm() {
  const p = document.getElementById('add-form-panel');
  p.style.display = 'block';
  p.scrollIntoView({ behavior: 'smooth', block: 'start' });
}
function hideAddForm() {
  document.getElementById('add-form-panel').style.display = 'none';
  document.getElementById('dform').reset();
}
function submitDoc(e) {
  e.preventDefault();
  const fn = document.getElementById('ffn').value.trim();
  const ln = document.getElementById('fln').value.trim();
  const em = document.getElementById('fem2').value.trim();
  const sp = document.getElementById('fsp').value;
  const li = document.getElementById('fli').value.trim();
  const ad = document.getElementById('fad').value.trim();
  if (docs.find(d => d.em === em)) { toast('✗', 'Cet email est déjà utilisé.', 'er'); return; }
  docs.push({ id: nid++, fn, ln, em, sp, lic: li, addr: ad || 'Tunisie', rat: 0, on: true });
  hideAddForm();
  render();
  toast('✅', `Dr. ${fn} ${ln} ajouté. Identifiants envoyés à ${em}`, 'ok');
}

// ── FILTER & SEARCH ────────────────────────────────────────────────────────
function filterD(m, el) {
  fm = m;
  document.querySelectorAll('.fchip').forEach(b => b.classList.remove('act'));
  el.classList.add('act');
  render();
}
function onSearch(q) { sq = q; render(); }

// ── MODAL ──────────────────────────────────────────────────────────────────
function openModal() { document.getElementById('mbg').classList.add('show'); }
function closeModal() { document.getElementById('mbg').classList.remove('show'); pendingAction = null; }
function confirmAction() { if (pendingAction) { pendingAction(); pendingAction = null; } closeModal(); }

// ── TOAST ──────────────────────────────────────────────────────────────────
let tt;
function toast(ic, msg, type) {
  const t = document.getElementById('toast');
  t.className = 'toast ' + (type === 'ok' ? 'ok' : 'er');
  document.getElementById('toast-ic').textContent = ic;
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  clearTimeout(tt);
  tt = setTimeout(() => t.classList.remove('show'), 3800);
}

function logout() { sessionStorage.clear(); window.location.href = '/'; }
</script>
