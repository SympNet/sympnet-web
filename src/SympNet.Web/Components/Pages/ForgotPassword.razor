@page "/forgot-password"
@layout EmptyLayout
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>SympNet — Mot de passe oublié</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>

<style>
:root{
  --b:#3ABFB8;--bd:#1A9E97;--bdd:#0D6E6A;--bddd:#084E4B;--bl:#6DD4CE;
  --bp:#E6F8F7;--bm:#F0FBFA;--w:#fff;--off:#F4FAFA;
  --bor:#DFF0EF;--bor2:#C5E8E7;
  --ink:#0B2D2C;--inm:#2E5554;--ind:#5E8584;--inf:#9DBDBC;
  --re:#EF4444;--reb:#FEF2F2;
  --ea:cubic-bezier(.22,1,.36,1);--sp:cubic-bezier(.34,1.56,.64,1);
  --fh:'Bricolage Grotesque',sans-serif;--fb:'Instrument Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--off);color:var(--ink);min-height:100vh;-webkit-font-smoothing:antialiased}
button{cursor:pointer;font-family:var(--fb);border:none;background:none}
input{font-family:var(--fb);outline:none}
a{text-decoration:none;color:inherit}
.page{display:flex;min-height:100vh;background:var(--w)}
.ll{flex:1;min-width:0;padding:52px 56px;background:linear-gradient(148deg,var(--bddd) 0%,var(--bdd) 40%,var(--bd) 70%,var(--b) 100%);display:flex;flex-direction:column;position:relative;overflow:hidden}
.ll::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 18% 22%,rgba(255,255,255,.07),transparent 55%),radial-gradient(circle at 80% 75%,rgba(255,255,255,.04),transparent 50%);pointer-events:none}
.ll::after{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.065) 1px,transparent 1px);background-size:30px 30px;pointer-events:none}
.arc{position:absolute;border-radius:50%;border:1px solid rgba(255,255,255,.07);pointer-events:none}
.arc1{width:620px;height:620px;right:-220px;top:-200px}
.arc2{width:360px;height:360px;right:-80px;bottom:-100px}
.arc3{width:200px;height:200px;left:60px;bottom:130px}
.ll-logo{display:flex;align-items:center;gap:13px;margin-bottom:60px;position:relative;z-index:2}
.ll-lic{width:46px;height:46px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.2);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;backdrop-filter:blur(6px)}
.ll-nm{font-family:var(--fh);font-size:27px;font-weight:800;color:#fff;letter-spacing:-.5px;line-height:1}
.ll-tg{font-size:10px;color:rgba(255,255,255,.5);margin-top:4px}
.ll-center{flex:1;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:2}
.ll-icon-wrap{width:72px;height:72px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);border-radius:20px;display:flex;align-items:center;justify-content:center;margin-bottom:26px;backdrop-filter:blur(8px)}
.ll-icon-wrap svg{width:34px;height:34px;color:#fff}
.ll-h{font-family:var(--fh);font-size:clamp(32px,3.5vw,48px);font-weight:800;color:#fff;line-height:1.06;letter-spacing:-1.5px;margin-bottom:16px}
.ll-h em{font-style:normal;color:var(--bl)}
.ll-p{font-size:15px;color:rgba(255,255,255,.55);line-height:1.75;max-width:360px}
.steps{display:flex;flex-direction:column;gap:14px;margin-top:40px}
.step{display:flex;align-items:center;gap:14px}
.snum{width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:13px;font-weight:700;color:#fff;flex-shrink:0}
.snum.done{background:var(--bl);border-color:var(--bl)}
.stxt{font-size:14px;color:rgba(255,255,255,.7);line-height:1.4}
.stxt b{color:#fff}
.lr{width:520px;flex-shrink:0;background:var(--w);display:flex;align-items:center;justify-content:center;padding:52px}
.lcard{width:100%;max-width:390px}
.card-icon{width:56px;height:56px;background:linear-gradient(135deg,var(--bdd),var(--b));border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:22px;box-shadow:0 8px 24px rgba(26,158,151,.3)}
.card-icon svg{width:26px;height:26px;color:#fff}
.card-h{font-family:var(--fh);font-size:24px;font-weight:800;color:var(--ink);letter-spacing:-.6px;margin-bottom:6px}
.card-p{font-size:13.5px;color:var(--inf);line-height:1.65;margin-bottom:28px}
.fld{margin-bottom:16px}
.fld label{display:block;font-size:12.5px;font-weight:600;color:var(--inm);margin-bottom:7px}
.ish{position:relative;display:flex;align-items:center}
.iico{position:absolute;left:13px;width:16px;height:16px;color:var(--inf);pointer-events:none;flex-shrink:0}
.ish input{width:100%;padding:12px 13px 12px 40px;border:1.5px solid var(--bor2);border-radius:10px;font-size:14px;color:var(--ink);background:var(--w);transition:border-color .18s,box-shadow .18s}
.ish input:focus{border-color:var(--b);box-shadow:0 0 0 3px rgba(58,191,184,.13)}
.ish input::placeholder{color:var(--inf)}
.btn-main{width:100%;padding:13.5px;color:#fff;border-radius:10px;font-size:14.5px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:9px;background:linear-gradient(135deg,var(--bdd),var(--b));box-shadow:0 6px 20px rgba(26,158,151,.3);transition:all .22s;margin-top:20px;margin-bottom:14px;border:none;cursor:pointer;font-family:var(--fb)}
.btn-main:hover{transform:translateY(-1px)}
.btn-main:disabled{opacity:.6;cursor:not-allowed}
.bsp{width:17px;height:17px;border:2px solid rgba(255,255,255,.35);border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite}
@@keyframes spin{to{transform:rotate(360deg)}}
.back-link{display:flex;align-items:center;justify-content:center;gap:7px;font-size:13.5px;font-weight:600;color:var(--ind);transition:color .15s;cursor:pointer;background:none;border:none;width:100%;font-family:var(--fb)}
.back-link:hover{color:var(--bdd)}
.lerr{margin-top:12px;padding:11px 14px;background:var(--reb);border:1px solid #FECACA;border-radius:10px;font-size:13px;color:var(--re);display:flex;align-items:center;gap:8px}
.lerr svg{width:15px;height:15px;flex-shrink:0}
.success-box{text-align:center}
.success-icon{width:70px;height:70px;background:linear-gradient(135deg,#F0FDF4,#dcfce7);border:2px solid #86efac;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:32px}
.success-h{font-family:var(--fh);font-size:20px;font-weight:800;color:var(--ink);letter-spacing:-.4px;margin-bottom:8px}
.success-p{font-size:13.5px;color:var(--ind);line-height:1.65;margin-bottom:24px}
.email-preview{background:var(--bm);border:1px solid var(--bor);border-radius:10px;padding:12px 16px;margin-bottom:24px;font-size:13px;color:var(--inm);display:flex;align-items:center;gap:10px}
.email-preview svg{width:16px;height:16px;color:var(--bd);flex-shrink:0}
.email-addr{font-weight:600;color:var(--ink)}
.resend-hint{font-size:12.5px;color:var(--inf);margin-top:10px;text-align:center}
.resend-hint span{color:var(--bd);font-weight:600;cursor:pointer}
@@media(max-width:820px){.ll{display:none}.lr{width:100%}}
</style>

<div class="page">
  <div class="ll">
    <div class="arc arc1"></div><div class="arc arc2"></div><div class="arc arc3"></div>
    <div class="ll-logo">
      <div class="ll-lic">
        <svg width="26" height="26" viewBox="0 0 26 26" fill="none">
          <line x1="13" y1="2" x2="13" y2="24" stroke="white" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M13 7C9.5 5 6 6.5 6 9.5C6 12.5 9.5 12.5 13 11" stroke="white" stroke-width="1.4" stroke-linecap="round" fill="none"/>
          <path d="M13 7C16.5 5 20 6.5 20 9.5C20 12.5 16.5 12.5 13 11" stroke="white" stroke-width="1.4" stroke-linecap="round" fill="none"/>
          <path d="M13 10C10 11.5 10 14.5 13 15.5C10 16.5 10 19.5 13 21" stroke="rgba(255,255,255,.8)" stroke-width="1.3" stroke-linecap="round" fill="none"/>
          <path d="M13 10C16 11.5 16 14.5 13 15.5C16 16.5 16 19.5 13 21" stroke="rgba(255,255,255,.8)" stroke-width="1.3" stroke-linecap="round" fill="none"/>
          <circle cx="13" cy="23" r="1.8" fill="rgba(255,255,255,.7)"/>
        </svg>
      </div>
      <div><div class="ll-nm">SympNet</div><div class="ll-tg">Système Intelligent de Support Décisionnel Clinique</div></div>
    </div>
    <div class="ll-center">
      <div class="ll-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
        </svg>
      </div>
      <h1 class="ll-h">Récupérez<br/>votre <em>accès</em><br/>sécurisé</h1>
      <p class="ll-p">Nous vous enverrons un lien de réinitialisation sécurisé valable 15 minutes.</p>
      <div class="steps">
        <div class="step"><div class="snum done">1</div><div class="stxt"><b>Entrez votre email</b> — celui lié à votre compte SympNet</div></div>
        <div class="step"><div class="snum">2</div><div class="stxt"><b>Consultez votre boîte mail</b> — un lien sécurisé vous sera envoyé</div></div>
        <div class="step"><div class="snum">3</div><div class="stxt"><b>Définissez un nouveau mot de passe</b> et reconnectez-vous</div></div>
      </div>
    </div>
  </div>

  <div class="lr">
    <div class="lcard">
      @if (sent)
      {
        <div class="success-box">
          <div class="success-icon">📬</div>
          <div class="success-h">Email envoyé !</div>
          <p class="success-p">Un lien de réinitialisation a été envoyé. Vérifiez votre boîte de réception et vos spams.</p>
          <div class="email-preview">
            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            <span>Envoyé à <span class="email-addr">@email</span></span>
          </div>
          <button class="btn-main" @onclick='() => Nav.NavigateTo("/login")'>
            Retour à la connexion
          </button>
          <p class="resend-hint">Pas reçu ? <span @onclick="Submit">Renvoyer l'email</span></p>
        </div>
      }
      else
      {
        <div class="card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div class="card-h">Mot de passe oublié ?</div>
        <p class="card-p">Entrez l'adresse email associée à votre compte. Nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
        <div class="fld">
          <label>Adresse email</label>
          <div class="ish">
            <svg class="iico" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
            <input type="email" @bind="email" @bind:event="oninput" placeholder="votre@email.com" autocomplete="email"/>
          </div>
        </div>
        @if (errorMsg != null)
        {
          <div class="lerr">
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            @errorMsg
          </div>
        }
        <button class="btn-main" @onclick="Submit" disabled="@loading">
          @if (loading) { <div class="bsp"></div> }
          else { <span>Envoyer le lien de réinitialisation</span> }
        </button>
        <button class="back-link" @onclick='() => Nav.NavigateTo("/login")'>
          <svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Retour à la connexion
        </button>
      }
    </div>
  </div>
</div>

@code {
    private string email = "";
    private string? errorMsg = null;
    private bool loading = false;
    private bool sent = false;

    private async Task Submit()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(email) || !email.Contains('@'))
        {
            errorMsg = "Veuillez saisir une adresse email valide.";
            return;
        }
        loading = true;
        try
        {
            await Http.PostAsJsonAsync("api/auth/forgot-password", new { Email = email });
            sent = true;
        }
        catch
        {
            errorMsg = "Une erreur est survenue. Vérifiez que l'API est démarrée.";
        }
        finally { loading = false; }
    }
}
