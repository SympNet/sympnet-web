@page "/forgot-password"
@inject HttpClient Http
@inject NavigationManager Navigation

<style>
    .forgot-password-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: linear-gradient(135deg, #084E4B, #1A9E97);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .forgot-password-card {
        background: white;
        padding: 2rem;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 400px;
    }
    
    .forgot-password-card h2 {
        color: #084E4B;
        margin-bottom: 1rem;
        text-align: center;
    }
    
    .forgot-password-card p {
        color: #5E8584;
        text-align: center;
        margin-bottom: 1.5rem;
    }
    
    .form-group {
        margin-bottom: 1rem;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        color: #5E8584;
        font-weight: 500;
    }
    
    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #DFF0EF;
        border-radius: 8px;
        font-size: 1rem;
    }
    
    .form-control:focus {
        outline: none;
        border-color: #1A9E97;
        box-shadow: 0 0 0 2px rgba(26,158,151,0.2);
    }
    
    .btn {
        width: 100%;
        padding: 0.75rem;
        background: linear-gradient(135deg, #0D6E6A, #3ABFB8);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        margin-top: 1rem;
        transition: opacity 0.3s;
    }
    
    .btn:hover {
        opacity: 0.9;
    }
    
    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
    
    .alert {
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }
    
    .alert-danger {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    
    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    
    .spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
        margin-right: 8px;
    }
    
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<PageTitle>Mot de passe oublié - SympNet</PageTitle>

<div class="forgot-password-container">
    <div class="forgot-password-card">
        <h2>🔐 Mot de passe oublié ?</h2>
        <p>Entrez votre email, nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
        
        @if (!IsSuccess)
        {
            <form @onsubmit="HandleForgotPassword">
                <div class="form-group">
                    <label>📧 Adresse email</label>
                    <input type="email" 
                           @bind="Email" 
                           class="form-control" 
                           placeholder="exemple@email.com" 
                           required />
                </div>
                
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger">
                        ⚠️ @ErrorMessage
                    </div>
                }
                
                <button type="submit" class="btn" disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="spinner"></span>
                    }
                    @(IsLoading ? "Envoi en cours..." : "📧 Envoyer le lien")
                </button>
            </form>
            
            <div style="text-align: center; margin-top: 1rem;">
                <a href="/login" style="color: #1A9E97; text-decoration: none;">Retour à la connexion</a>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                <p style="text-align:center; margin-bottom:1rem;">
                    ✅ Si un compte existe avec cet email, un lien de réinitialisation vous a été envoyé.
                </p>
                <button @onclick="GoToLogin" class="btn" style="margin-top:0;">🔑 Retour à la connexion</button>
            </div>
        }
    </div>
</div>

@code {
    private string Email = "";
    private bool IsLoading = false;
    private string ErrorMessage = "";
    private bool IsSuccess = false;
    
    private async Task HandleForgotPassword()
    {
        if (string.IsNullOrWhiteSpace(Email))
        {
            ErrorMessage = "Veuillez saisir votre email.";
            return;
        }
        
        IsLoading = true;
        ErrorMessage = "";
        StateHasChanged();
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", 
                new { Email = Email });
            
            if (response.IsSuccessStatusCode)
            {
                IsSuccess = true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                ErrorMessage = error?.message ?? "Erreur lors de l'envoi. Veuillez réessayer.";
            }
        }
        catch (HttpRequestException ex)
        {
            ErrorMessage = $"Impossible de contacter le serveur. Vérifiez que l'API est démarrée sur le port 5237. ({ex.Message})";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
    
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }
    
    private class ErrorResponse
    {
        public string? message { get; set; }
    }
}