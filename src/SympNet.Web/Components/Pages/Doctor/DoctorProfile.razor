@page "/doctor/profile"
@layout Shared.DoctorLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS

<PageTitle>SympNet — Mon Profil Médecin</PageTitle>

<style>
    :root {
        --primary: #0D9488;
        --primary-dark: #0B7B70;
        --success: #10B981;
        --warning: #F59E0B;
        --danger: #EF4444;
        --gray: #6B7280;
        --white: #FFFFFF;
        --light: #F9FAFB;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --radius-lg: 16px;
        --radius-xl: 24px;
    }

    .profile-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .profile-card {
        background: var(--white);
        border-radius: var(--radius-xl);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(13, 148, 136, 0.1);
    }

    .profile-header {
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        padding: 40px 32px;
        position: relative;
    }

    .profile-avatar-container {
        display: flex;
        align-items: center;
        gap: 28px;
        flex-wrap: wrap;
    }

    .avatar-wrapper {
        position: relative;
        cursor: pointer;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: 800;
        color: white;
        border: 3px solid rgba(255, 255, 255, 0.3);
        object-fit: cover;
        transition: all 0.3s ease;
    }

    .avatar-wrapper:hover .profile-avatar {
        opacity: 0.8;
    }

    .avatar-overlay {
        position: absolute;
        bottom: 0;
        right: 0;
        background: white;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0D9488;
        cursor: pointer;
        box-shadow: var(--shadow-sm);
        border: 2px solid white;
    }

    .profile-info h2 {
        font-size: 24px;
        font-weight: 700;
        color: white;
        margin-bottom: 6px;
    }

    .profile-info p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.8);
    }

    .edit-badge {
        background: rgba(255, 255, 255, 0.2);
        padding: 4px 12px;
        border-radius: 100px;
        font-size: 12px;
        margin-top: 8px;
        display: inline-block;
        cursor: pointer;
        transition: all 0.2s;
    }

    .edit-badge:hover {
        background: rgba(255, 255, 255, 0.3);
    }

    .profile-body {
        padding: 28px 32px;
    }

    .form-section {
        background: var(--light);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin-bottom: 24px;
        border: 1px solid rgba(13, 148, 136, 0.1);
    }

    .form-section-title {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #1F2937;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 10px;
        border-bottom: 2px solid rgba(13, 148, 136, 0.2);
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-group {
        margin-bottom: 12px;
    }

    .form-group label {
        display: block;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--gray);
        margin-bottom: 4px;
    }

    .form-group input, .form-group select, .form-group textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1.5px solid #E5E7EB;
        border-radius: 10px;
        font-size: 14px;
        font-family: 'Instrument Sans', sans-serif;
        transition: all 0.2s;
        background: white;
    }

    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
    }

    .form-group input:disabled {
        background: #F9FAFB;
        color: #9CA3AF;
        cursor: not-allowed;
    }

    .full-width {
        grid-column: span 2;
    }

    .btn-save, .btn-cancel {
        padding: 8px 20px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-family: 'Instrument Sans', sans-serif;
    }

    .btn-save {
        background: linear-gradient(135deg, #0D9488, #14B8A6);
        color: white;
    }

    .btn-save:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-sm);
    }

    .btn-cancel {
        background: #F3F4F6;
        color: #6B7280;
    }

    .btn-cancel:hover {
        background: #E5E7EB;
    }

    .password-section {
        background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
        border-radius: var(--radius-lg);
        padding: 20px 24px;
        margin-bottom: 24px;
    }

    .password-section .form-section-title {
        border-bottom-color: rgba(245, 158, 11, 0.3);
        color: #92400E;
    }

    .alert-success {
        background: #D1FAE5;
        color: #065F46;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 4px solid #10B981;
        font-size: 13px;
    }

    .alert-error {
        background: #FEE2E2;
        color: #991B1B;
        padding: 12px 16px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-left: 4px solid #EF4444;
        font-size: 13px;
    }

    .stats-mini {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .stat-mini-card {
        background: white;
        border-radius: var(--radius-lg);
        padding: 16px;
        text-align: center;
        border: 1px solid rgba(13, 148, 136, 0.1);
        transition: all 0.2s;
    }

    .stat-mini-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    .stat-mini-value {
        font-size: 28px;
        font-weight: 800;
        color: var(--primary);
    }

    .stat-mini-label {
        font-size: 11px;
        color: var(--gray);
        margin-top: 4px;
    }

    .timeline-item {
        display: flex;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .timeline-item:last-child {
        border-bottom: none;
    }

    .timeline-icon {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(13, 148, 136, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #0D9488;
        flex-shrink: 0;
    }

    .timeline-title {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 2px;
    }

    .timeline-date {
        font-size: 11px;
        color: var(--gray);
    }

    .file-input-hidden {
        display: none;
    }

    .spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        display: inline-block;
        margin-right: 6px;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
        .full-width {
            grid-column: span 1;
        }
        .profile-body {
            padding: 20px;
        }
        .stats-mini {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="profile-container">
    @if (isLoading)
    {
        <div style="text-align: center; padding: 60px;">
            <div style="width: 40px; height: 40px; border: 3px solid rgba(13,148,136,0.1); border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px;"></div>
            <p style="color: var(--gray);">Chargement de votre profil...</p>
        </div>
    }
    else
    {
        <div class="profile-card">
            <!-- Header avec avatar -->
            <div class="profile-header">
                <div class="profile-avatar-container">
                    <div class="avatar-wrapper" @onclick="TriggerFileUpload">
                        @if (!string.IsNullOrEmpty(profileImageBase64))
                        {
                            <img src="@profileImageBase64" class="profile-avatar" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="profile-avatar">@(userInitial)</div>
                        }
                        <div class="avatar-overlay">
                            <i class="fas fa-camera" style="font-size: 14px;"></i>
                        </div>
                    </div>
                    <div class="profile-info">
                        <h2>Dr. @doctorInfo.FirstName @doctorInfo.LastName</h2>
                        <p><i class="fas fa-envelope"></i> @userEmail</p>
                        <div class="edit-badge" @onclick="() => isEditing = !isEditing">
                            <i class="fas fa-@(isEditing ? "times" : "pen")"></i> @(isEditing ? "Annuler" : "Modifier le profil")
                        </div>
                    </div>
                </div>
            </div>

            <div class="profile-body">
                <!-- Messages -->
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert-success">
                        <i class="fas fa-check-circle"></i>
                        <span>@successMessage</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert-error">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>@errorMessage</span>
                    </div>
                }

                <!-- Mini Stats -->
                <div class="stats-mini">
                    <div class="stat-mini-card">
                        <div class="stat-mini-value">@totalPatients</div>
                        <div class="stat-mini-label">Patients traités</div>
                    </div>
                    <div class="stat-mini-card">
                        <div class="stat-mini-value">@totalConsultations</div>
                        <div class="stat-mini-label">Consultations</div>
                    </div>
                    <div class="stat-mini-card">
                        <div class="stat-mini-value">@averageRating.ToString("0.0") ★</div>
                        <div class="stat-mini-label">Note moyenne</div>
                    </div>
                </div>

                <!-- Informations personnelles -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-user-md" style="color: #0D9488;"></i>
                        Informations personnelles
                    </div>
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Prénom</label>
                            <input type="text" @bind="doctorInfo.FirstName" disabled="@(!isEditing)" />
                        </div>
                        <div class="form-group">
                            <label>Nom</label>
                            <input type="text" @bind="doctorInfo.LastName" disabled="@(!isEditing)" />
                        </div>
                        <div class="form-group">
                            <label>Téléphone</label>
                            <input type="tel" @bind="doctorInfo.PhoneNumber" placeholder="+216 XX XXX XXX" disabled="@(!isEditing)" />
                        </div>
                        <div class="form-group">
                            <label>Spécialité</label>
                            <select @bind="doctorInfo.Speciality" disabled="@(!isEditing)">
                                <option>Médecine Générale</option>
                                <option>Cardiologie</option>
                                <option>Dermatologie</option>
                                <option>Pédiatrie</option>
                                <option>Ophtalmologie</option>
                                <option>Gynécologie</option>
                                <option>Neurologie</option>
                                <option>Psychiatrie</option>
                                <option>Orthopédie</option>
                                <option>Pneumologie</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Numéro de licence</label>
                            <input type="text" @bind="doctorInfo.LicenseNumber" disabled="@(!isEditing)" />
                        </div>
                        <div class="form-group">
                            <label>Email professionnel</label>
                            <input type="email" @bind="doctorInfo.Email" disabled="@(!isEditing)" />
                        </div>
                        <div class="form-group full-width">
                            <label>Adresse du cabinet</label>
                            <textarea rows="2" @bind="doctorInfo.Address" disabled="@(!isEditing)"></textarea>
                        </div>
                    </div>
                    
                    @if (isEditing)
                    {
                        <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 20px;">
                            <button class="btn-cancel" @onclick="CancelEdit">Annuler</button>
                            <button class="btn-save" @onclick="SaveProfile">Enregistrer</button>
                        </div>
                    }
                </div>

                <!-- Changement de mot de passe -->
                <div class="password-section">
                    <div class="form-section-title">
                        <i class="fas fa-lock" style="color: #F59E0B;"></i>
                        Sécurité
                    </div>
                    
                    <div class="form-grid">
                        <div class="form-group">
                            <label>Mot de passe actuel</label>
                            <input type="password" @bind="currentPassword" placeholder="••••••••" />
                        </div>
                        <div class="form-group">
                            <label>Nouveau mot de passe</label>
                            <input type="password" @bind="newPassword" placeholder="••••••••" />
                        </div>
                        <div class="form-group">
                            <label>Confirmer</label>
                            <input type="password" @bind="confirmPassword" placeholder="••••••••" />
                        </div>
                    </div>
                    
                    <div style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 16px;">
                        <button class="btn-save" @onclick="ChangePassword" disabled="@passwordLoading">
                            @if (passwordLoading)
                            {
                                <span><span class="spinner"></span> Modification...</span>
                            }
                            else
                            {
                                <span><i class="fas fa-key"></i> Changer le mot de passe</span>
                            }
                        </button>
                    </div>
                </div>

                <!-- Activité récente -->
                <div class="form-section" style="margin-bottom: 0;">
                    <div class="form-section-title">
                        <i class="fas fa-history" style="color: #0D9488;"></i>
                        Activité récente
                    </div>
                    @foreach (var activity in activities)
                    {
                        <div class="timeline-item">
                            <div class="timeline-icon">
                                <i class="fas @activity.Icon"></i>
                            </div>
                            <div>
                                <div class="timeline-title">@activity.Title</div>
                                <div class="timeline-date">@activity.Date.ToString("dd MMMM yyyy, HH:mm", new System.Globalization.CultureInfo("fr-FR"))</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    
    <!-- InputFile caché -->
    <InputFile id="avatarFileInput" class="file-input-hidden" OnChange="HandleImageUpload" accept="image/*" />
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }

    private string userEmail = "";
    private string userInitial = "";
    private bool isLoading = true;
    private bool isEditing = false;
    private string profileImageBase64 = "";
    private string successMessage = "";
    private string errorMessage = "";
    
    private int totalPatients = 128;
    private int totalConsultations = 45;
    private double averageRating = 4.8;
    
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private bool passwordLoading = false;
    
    private DoctorInfoDto doctorInfo = new();
    private DoctorInfoDto originalDoctorInfo = new();
    private List<ActivityDto> activities = new();

    private async Task TriggerFileUpload()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('avatarFileInput').click()");
    }

    protected override async Task OnInitializedAsync()
    {
        userEmail = Email ?? "";
        userInitial = userEmail.Length > 0 ? userEmail[0].ToString().ToUpper() : "D";
        
        if (!string.IsNullOrEmpty(Token))
        {
            Http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        }

        await LoadProfileData();
        isLoading = false;
    }

    private async Task LoadProfileData()
    {
        try
        {
            await Task.Delay(500);
            
            string firstName = userEmail.Split('@')[0];
            if (firstName.Contains('.')) firstName = firstName.Split('.')[0];
            
            doctorInfo = new DoctorInfoDto
            {
                FirstName = firstName.Length > 0 ? char.ToUpper(firstName[0]) + firstName.Substring(1) : "Médecin",
                LastName = "User",
                Email = userEmail,
                Speciality = "Médecine Générale",
                LicenseNumber = "MED-" + DateTime.Now.Year + "-" + new Random().Next(1000, 9999),
                Address = "Centre Médical SympNet, Tunis, Tunisie",
                PhoneNumber = "+216 99 999 999"
            };
            
            originalDoctorInfo = new DoctorInfoDto
            {
                FirstName = doctorInfo.FirstName,
                LastName = doctorInfo.LastName,
                Email = doctorInfo.Email,
                Speciality = doctorInfo.Speciality,
                LicenseNumber = doctorInfo.LicenseNumber,
                Address = doctorInfo.Address,
                PhoneNumber = doctorInfo.PhoneNumber
            };

            activities = new List<ActivityDto>
            {
                new() { Title = "Connexion à la plateforme", Date = DateTime.Now.AddHours(-2), Icon = "fa-sign-in-alt" },
                new() { Title = "Consultation patient #1245", Date = DateTime.Now.AddHours(-3), Icon = "fa-stethoscope" },
                new() { Title = "Analyse IA terminée", Date = DateTime.Now.AddHours(-5), Icon = "fa-microscope" }
            };
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur: " + ex.Message;
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file != null && file.Size > 0 && file.Size < 2 * 1024 * 1024)
            {
                var buffer = new byte[file.Size];
                await using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024);
                await stream.ReadAsync(buffer);
                
                var base64 = Convert.ToBase64String(buffer);
                var extension = Path.GetExtension(file.Name).ToLower();
                var mimeType = extension switch
                {
                    ".png" => "image/png",
                    ".jpg" or ".jpeg" => "image/jpeg",
                    _ => "image/jpeg"
                };
                
                profileImageBase64 = $"data:{mimeType};base64,{base64}";
                successMessage = "Photo mise à jour !";
                await Task.Delay(2000);
                successMessage = "";
            }
            else
            {
                errorMessage = "Fichier trop volumineux (max 2MB)";
                await Task.Delay(2000);
                errorMessage = "";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur: " + ex.Message;
            await Task.Delay(2000);
            errorMessage = "";
        }
    }

    private async Task SaveProfile()
    {
        try
        {
            await Task.Delay(500);
            originalDoctorInfo = new DoctorInfoDto
            {
                FirstName = doctorInfo.FirstName,
                LastName = doctorInfo.LastName,
                Email = doctorInfo.Email,
                Speciality = doctorInfo.Speciality,
                LicenseNumber = doctorInfo.LicenseNumber,
                Address = doctorInfo.Address,
                PhoneNumber = doctorInfo.PhoneNumber
            };
            userInitial = doctorInfo.FirstName.Length > 0 ? doctorInfo.FirstName[0].ToString().ToUpper() : "D";
            isEditing = false;
            successMessage = "Profil mis à jour !";
            await Task.Delay(2000);
            successMessage = "";
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur: " + ex.Message;
            await Task.Delay(2000);
            errorMessage = "";
        }
    }

    private void CancelEdit()
    {
        doctorInfo = new DoctorInfoDto
        {
            FirstName = originalDoctorInfo.FirstName,
            LastName = originalDoctorInfo.LastName,
            Email = originalDoctorInfo.Email,
            Speciality = originalDoctorInfo.Speciality,
            LicenseNumber = originalDoctorInfo.LicenseNumber,
            Address = originalDoctorInfo.Address,
            PhoneNumber = originalDoctorInfo.PhoneNumber
        };
        isEditing = false;
    }

    private async Task ChangePassword()
    {
        if (string.IsNullOrWhiteSpace(currentPassword))
        {
            errorMessage = "Mot de passe actuel requis";
            return;
        }
        if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 6)
        {
            errorMessage = "Nouveau mot de passe (min 6 caractères)";
            return;
        }
        if (newPassword != confirmPassword)
        {
            errorMessage = "Les mots de passe ne correspondent pas";
            return;
        }
        
        passwordLoading = true;
        try
        {
            await Task.Delay(1000);
            successMessage = "Mot de passe changé !";
            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
            await Task.Delay(2000);
            successMessage = "";
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur: " + ex.Message;
            await Task.Delay(2000);
            errorMessage = "";
        }
        finally
        {
            passwordLoading = false;
        }
    }

    public class DoctorInfoDto
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Speciality { get; set; } = "Médecine Générale";
        public string LicenseNumber { get; set; } = "";
        public string Address { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
    }

    public class ActivityDto
    {
        public string Title { get; set; } = "";
        public DateTime Date { get; set; }
        public string Icon { get; set; } = "";
    }
}