@page "/doctor/dashboard"
@layout Shared.DoctorLayout
@inject NavigationManager Nav
@inject HttpClient Http
@using System.Text.Json

<PageTitle>SympNet — Tableau de Bord Médecin</PageTitle>

<style>
    :root {
        --primary: #0D9488;
        --success: #10B981;
        --gray: #6B7280;
        --white: #FFFFFF;
        --light: #F9FAFB;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --radius-lg: 16px;
        --radius-xl: 24px;
    }

    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .welcome-banner {
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: var(--radius-xl);
        padding: 32px 40px;
        margin-bottom: 32px;
    }

    .welcome-banner h1 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 28px;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
    }

    .welcome-banner p {
        color: rgba(255, 255, 255, 0.8);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        padding: 20px;
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(13, 148, 136, 0.1);
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 12px;
    }

    .stat-icon.blue { background: rgba(59, 130, 246, 0.1); color: #3B82F6; }
    .stat-icon.green { background: rgba(16, 185, 129, 0.1); color: #10B981; }
    .stat-icon.teal { background: rgba(13, 148, 136, 0.1); color: #0D9488; }

    .stat-value {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 13px;
        color: var(--gray);
    }

    .info-card {
        background: var(--white);
        border-radius: var(--radius-lg);
        border: 1px solid rgba(13, 148, 136, 0.1);
        margin-bottom: 24px;
    }

    .info-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(13, 148, 136, 0.1);
    }

    .info-card-header h3 {
        font-size: 16px;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-card-body {
        padding: 20px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-size: 13px;
        color: var(--gray);
    }

    .info-value {
        font-size: 14px;
        font-weight: 600;
    }

    .status-active {
        color: var(--success);
    }

    .badge-coming {
        background: rgba(13, 148, 136, 0.1);
        color: #0D9488;
        font-size: 11px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 100px;
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dashboard-container">
    <div class="welcome-banner">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h1>Bonjour, Dr. @userEmail 👋</h1>
                <p>Voici votre tableau de bord clinique SympNet</p>
            </div>
            <div>
                <div style="font-size: 34px; font-weight: 800; color: white;">@DateTime.Now.Day</div>
                <div style="font-size: 12px; opacity: 0.7;">@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</div>
            </div>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-users"></i></div>
            <div class="stat-value">@consultations.Select(c => c.PatientId).Distinct().Count()</div>
            <div class="stat-label">Mes Patients</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-value">@consultations.Count(c => c.CreatedAt.Date == DateTime.Today)</div>
            <div class="stat-label">Rendez-vous aujourd'hui</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon teal"><i class="fas fa-microscope"></i></div>
            <div class="stat-value">@consultations.Count</div>
            <div class="stat-label">Consultations IA</div>
        </div>
    </div>

    <div class="info-card">
        <div class="info-card-header">
            <h3><i class="fas fa-hospital-user" style="color: #0D9488;"></i> Informations du compte</h3>
        </div>
        <div class="info-card-body">
            <div class="info-row">
                <span class="info-label">Email</span>
                <span class="info-value">@userEmail</span>
            </div>
            <div class="info-row">
                <span class="info-label">Rôle</span>
                <span class="info-value">Médecin</span>
            </div>
            <div class="info-row">
                <span class="info-label">Statut</span>
                <span class="info-value status-active">✓ Compte actif</span>
            </div>
        </div>
    </div>

    <div class="info-card">
        <div class="info-card-header">
            <h3><i class="fas fa-rocket" style="color: #0D9488;"></i> Fonctionnalités à venir</h3>
        </div>
        <div class="info-card-body">
            <div class="info-row">
                <span class="info-label">Gestion des patients</span>
                <span class="badge-coming">Sprint 2</span>
            </div>
            <div class="info-row">
                <span class="info-label">Rendez-vous</span>
                <span class="badge-coming">Sprint 2</span>
            </div>
            <div class="info-row">
                <span class="info-label">Diagnostic IA avancé</span>
                <span class="badge-coming">Sprint 3</span>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }

    private string userEmail = "";
    private List<ConsultationDto> consultations = new();

    protected override async Task OnInitializedAsync()
    {
        userEmail = Email ?? "";
        
        if (!string.IsNullOrEmpty(Token))
        {
            Http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            // Pour l'instant, on utilise des données de démo
            consultations = GetDemoConsultations();
        }
        catch { }
    }

    private List<ConsultationDto> GetDemoConsultations() => new()
    {
        new ConsultationDto { Id = 1, PatientId = 101, PatientName = "Ahmed Ben Ali", PatientEmail = "ahmed@email.com", CreatedAt = DateTime.Now.AddHours(-2) },
        new ConsultationDto { Id = 2, PatientId = 102, PatientName = "Sonia Trabelsi", PatientEmail = "sonia@email.com", CreatedAt = DateTime.Now.AddHours(-5) },
        new ConsultationDto { Id = 3, PatientId = 103, PatientName = "Karim Mansouri", PatientEmail = "karim@email.com", CreatedAt = DateTime.Now.AddDays(-1) },
        new ConsultationDto { Id = 4, PatientId = 101, PatientName = "Ahmed Ben Ali", PatientEmail = "ahmed@email.com", CreatedAt = DateTime.Now.AddDays(-3) }
    };

    public class ConsultationDto
    {
        public int Id { get; set; }
        public int PatientId { get; set; }
        public string PatientName { get; set; } = "";
        public string PatientEmail { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}