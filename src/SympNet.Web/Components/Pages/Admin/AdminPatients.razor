@page "/admin/patients"
@using SympNet.Web.Components.Layout
@layout AdminLayout
@inject NavigationManager Nav
@inject HttpClient Http
@using System.Text.Json
@rendermode InteractiveServer

<PageTitle>SympNet — Gestion des Patients</PageTitle>

<style>
    .page-container { max-width: 1400px; margin: 0 auto; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 800; color: #1F2937; margin-bottom: 8px; }
    .stats-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
    .stat-card { background: white; border-radius: 16px; padding: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .patients-table { background: white; border-radius: 16px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 14px 20px; background: #F9FAFB; font-size: 12px; font-weight: 600; text-transform: uppercase; color: #6B7280; border-bottom: 1px solid rgba(13,148,136,0.1); }
    td { padding: 14px 20px; border-bottom: 1px solid rgba(13,148,136,0.05); font-size: 13px; }
    tr:hover { background: #F9FAFB; }
    .status-badge { display: inline-block; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; }
    .status-active { background: rgba(16,185,129,0.1); color: #10B981; }
    .status-inactive { background: rgba(239,68,68,0.1); color: #EF4444; }
    .btn-icon { background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; margin: 0 4px; }
    .btn-icon.activate { color: #10B981; }
    .btn-icon.deactivate { color: #F59E0B; }
    .alert-success { background: #D1FAE5; color: #065F46; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #10B981; }
    .alert-error { background: #FEE2E2; color: #991B1B; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #EF4444; }
</style>

<div class="page-container">
    <div class="page-header"><h1>👥 Gestion des Patients</h1><p>Consultez la liste des patients, activez ou désactivez des comptes</p></div>
    <div class="stats-cards">
        <div class="stat-card"><div class="stat-number">@patients.Count</div><div class="stat-label">Total Patients</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.IsActive)</div><div class="stat-label">Actifs</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => !p.IsActive)</div><div class="stat-label">Inactifs</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.Gender == "F")</div><div class="stat-label">Femmes</div></div>
    </div>
    @if (!string.IsNullOrEmpty(successMessage)) { <div class="alert-success">@successMessage</div> }
    @if (!string.IsNullOrEmpty(errorMessage)) { <div class="alert-error">@errorMessage</div> }
    @if (patients.Any())
    {
        <div class="patients-table">
             <table><thead><tr><th>Patient</th><th>Email</th><th>Téléphone</th><th>Âge</th><th>Genre</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var p in patients)
                {
                    <tr><td><strong>@p.FirstName @p.LastName</strong></td><td>@p.Email</td><td>@p.PhoneNumber</td><td>@(DateTime.Now.Year - p.DateOfBirth.Year) ans</td><td>@(p.Gender == "M" ? "Homme" : "Femme")</td>
                    <td><span class="status-badge @(p.IsActive ? "status-active" : "status-inactive")">@(p.IsActive ? "Actif" : "Inactif")</span></td>
                    <td>@if (p.IsActive) { <button class="btn-icon deactivate" @onclick="() => DeactivatePatient(p.Id)"><i class="fas fa-ban"></i></button> } else { <button class="btn-icon activate" @onclick="() => ActivatePatient(p.Id)"><i class="fas fa-check-circle"></i></button> }</td></tr>
                }
            </tbody></table>
        </div>
    }
    else { <div class="empty-state"><i class="fas fa-users" style="font-size: 48px;"></i><h3>Aucun patient</h3><p>Les patients apparaîtront ici après leur inscription</p></div> }
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    private List<PatientDto> patients = new();
    private string successMessage = "";
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Token)) Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        await LoadPatients();
    }
    private async Task LoadPatients()
    {
        try { var result = await Http.GetFromJsonAsync<List<PatientDto>>("api/admin/patients"); if (result != null) patients = result; else patients = GetDemoPatients(); }
        catch { patients = GetDemoPatients(); }
    }
    private async Task ActivatePatient(int id) { try { await Http.PutAsJsonAsync($"api/admin/patients/{id}/activate", new { }); successMessage = "Patient activé"; await LoadPatients(); } catch { errorMessage = "Erreur"; } await ClearMessages(); }
    private async Task DeactivatePatient(int id) { try { await Http.PutAsJsonAsync($"api/admin/patients/{id}/deactivate", new { }); successMessage = "Patient désactivé"; await LoadPatients(); } catch { errorMessage = "Erreur"; } await ClearMessages(); }
    private async Task ClearMessages() { await Task.Delay(3000); successMessage = ""; errorMessage = ""; }
    private List<PatientDto> GetDemoPatients() => new() { new PatientDto { Id = 1, FirstName = "Ahmed", LastName = "Ben Ali", Email = "ahmed@email.com", PhoneNumber = "+216 98 123 456", DateOfBirth = new DateTime(1990, 5, 15), Gender = "M", IsActive = true }, new PatientDto { Id = 2, FirstName = "Sonia", LastName = "Trabelsi", Email = "sonia@email.com", PhoneNumber = "+216 97 234 567", DateOfBirth = new DateTime(1985, 8, 22), Gender = "F", IsActive = true } };
    public class PatientDto { public int Id { get; set; } public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; public string Email { get; set; } = ""; public string PhoneNumber { get; set; } = ""; public DateTime DateOfBirth { get; set; } public string Gender { get; set; } = ""; public bool IsActive { get; set; } }
}