@page "/admin/doctors"
@using SympNet.Web.Components.Layout
@layout AdminLayout
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Text.Json
@rendermode InteractiveServer

<PageTitle>SympNet — Gestion des Médecins</PageTitle>

<style>
    .page-container { max-width: 1400px; margin: 0 auto; }
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 800; color: #1F2937; margin-bottom: 8px; }
    .stats-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 28px; }
    .stat-card { background: white; border-radius: 16px; padding: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .btn-add { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; padding: 10px 20px; border-radius: 12px; border: none; font-weight: 600; cursor: pointer; margin-bottom: 20px; display: inline-flex; align-items: center; gap: 8px; }
    .doctors-table { background: white; border-radius: 16px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 14px 20px; background: #F9FAFB; font-size: 12px; font-weight: 600; text-transform: uppercase; color: #6B7280; border-bottom: 1px solid rgba(13,148,136,0.1); }
    td { padding: 14px 20px; border-bottom: 1px solid rgba(13,148,136,0.05); font-size: 13px; }
    tr:hover { background: #F9FAFB; }
    .status-badge { display: inline-block; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; }
    .status-active { background: rgba(16,185,129,0.1); color: #10B981; }
    .status-inactive { background: rgba(239,68,68,0.1); color: #EF4444; }
    .btn-icon { background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; margin: 0 4px; }
    .btn-icon.activate { color: #10B981; }
    .btn-icon.deactivate { color: #F59E0B; }
    .btn-icon.delete { color: #EF4444; }
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-content { background: white; border-radius: 24px; max-width: 500px; width: 90%; padding: 28px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 6px; color: #374151; }
    .form-group input, .form-group select { width: 100%; padding: 10px 12px; border: 1.5px solid #E5E7EB; border-radius: 10px; font-size: 14px; }
    .alert-success { background: #D1FAE5; color: #065F46; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #10B981; }
    .alert-error { background: #FEE2E2; color: #991B1B; padding: 12px 16px; border-radius: 12px; margin-bottom: 20px; border-left: 4px solid #EF4444; }
</style>

<div class="page-container">
    <div class="page-header"><h1>👨‍⚕️ Gestion des Médecins</h1><p>Créez, activez, désactivez ou supprimez des comptes médecins</p></div>
    <div class="stats-cards">
        <div class="stat-card"><div class="stat-number">@doctors.Count</div><div class="stat-label">Total Médecins</div></div>
        <div class="stat-card"><div class="stat-number">@doctors.Count(d => d.IsValidated)</div><div class="stat-label">Actifs</div></div>
        <div class="stat-card"><div class="stat-number">@doctors.Count(d => !d.IsValidated)</div><div class="stat-label">En attente</div></div>
    </div>
    <button class="btn-add" @onclick="() => showAddModal = true"><i class="fas fa-plus"></i> Ajouter un médecin</button>
    @if (!string.IsNullOrEmpty(successMessage)) { <div class="alert-success">@successMessage</div> }
    @if (!string.IsNullOrEmpty(errorMessage)) { <div class="alert-error">@errorMessage</div> }
    @if (doctors.Any())
    {
        <div class="doctors-table">
            <table><thead><tr><th>Médecin</th><th>Spécialité</th><th>Email</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var d in doctors)
                {
                    <tr><td><strong>Dr. @d.FirstName @d.LastName</strong></td><td>@d.Speciality</td><td>@d.Email</td>
                    <td><span class="status-badge @(d.IsValidated ? "status-active" : "status-inactive")">@(d.IsValidated ? "Actif" : "Inactif")</span></td>
                    <td>
                        @if (d.IsValidated) { <button class="btn-icon deactivate" @onclick="() => DeactivateDoctor(d.Id)"><i class="fas fa-ban"></i></button> }
                        else { <button class="btn-icon activate" @onclick="() => ActivateDoctor(d.Id)"><i class="fas fa-check-circle"></i></button> }
                        <button class="btn-icon delete" @onclick="() => DeleteDoctor(d.Id)"><i class="fas fa-trash"></i></button>
                    </td></tr>
                }
            </tbody></table>
        </div>
    }
    else { <div class="empty-state"><i class="fas fa-user-md" style="font-size: 48px;"></i><h3>Aucun médecin</h3><p>Ajoutez votre premier médecin</p></div> }
    @if (showAddModal)
    {
        <div class="modal-overlay" @onclick="() => showAddModal = false">
            <div class="modal-content" @onclick:stopPropagation>
                <h3>Ajouter un médecin</h3>
                <div class="form-group"><label>Prénom</label><input type="text" @bind="newDoctor.FirstName" /></div>
                <div class="form-group"><label>Nom</label><input type="text" @bind="newDoctor.LastName" /></div>
                <div class="form-group"><label>Email</label><input type="email" @bind="newDoctor.Email" /></div>
                <div class="form-group"><label>Spécialité</label><select @bind="newDoctor.Speciality"><option>Médecine Générale</option><option>Cardiologie</option><option>Dermatologie</option><option>Pédiatrie</option><option>Ophtalmologie</option><option>Neurologie</option></select></div>
                <div class="form-group"><label>Téléphone</label><input type="tel" @bind="newDoctor.PhoneNumber" /></div>
                <div style="display: flex; gap: 12px; justify-content: flex-end;"><button class="btn-cancel" style="padding: 8px 20px; background: #F3F4F6; border-radius: 10px;" @onclick="() => showAddModal = false">Annuler</button><button class="btn-save" style="padding: 8px 20px; background: #0D9488; color: white; border-radius: 10px;" @onclick="CreateDoctor" disabled="@isLoading">@(isLoading ? "Création..." : "Créer")</button></div>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    private List<DoctorDto> doctors = new();
    private bool showAddModal = false;
    private bool isLoading = false;
    private string successMessage = "";
    private string errorMessage = "";
    private CreateDoctorDto newDoctor = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Token)) Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        await LoadDoctors();
    }
    private async Task LoadDoctors()
    {
        try { var result = await Http.GetFromJsonAsync<List<DoctorDto>>("api/admin/doctors"); if (result != null) doctors = result; else doctors = GetDemoDoctors(); }
        catch { doctors = GetDemoDoctors(); }
    }
    private async Task CreateDoctor()
    {
        if (string.IsNullOrWhiteSpace(newDoctor.Email) || string.IsNullOrWhiteSpace(newDoctor.FirstName)) { errorMessage = "Email et prénom sont requis"; await ClearMessages(); return; }
        isLoading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/admin/doctors", newDoctor);
            if (response.IsSuccessStatusCode) { successMessage = $"Médecin {newDoctor.FirstName} {newDoctor.LastName} créé !"; newDoctor = new CreateDoctorDto(); showAddModal = false; await LoadDoctors(); }
            else { errorMessage = "Erreur lors de la création"; }
        }
        catch { errorMessage = "Erreur de connexion"; }
        finally { isLoading = false; await ClearMessages(); }
    }
    private async Task ActivateDoctor(int id) { try { await Http.PutAsJsonAsync($"api/admin/doctors/{id}/activate", new { }); successMessage = "Médecin activé"; await LoadDoctors(); } catch { errorMessage = "Erreur"; } await ClearMessages(); }
    private async Task DeactivateDoctor(int id) { try { await Http.PutAsJsonAsync($"api/admin/doctors/{id}/deactivate", new { }); successMessage = "Médecin désactivé"; await LoadDoctors(); } catch { errorMessage = "Erreur"; } await ClearMessages(); }
    private async Task DeleteDoctor(int id) { if (!await JS.InvokeAsync<bool>("confirm", "Supprimer définitivement ?")) return; try { await Http.DeleteAsync($"api/admin/doctors/{id}"); successMessage = "Médecin supprimé"; await LoadDoctors(); } catch { errorMessage = "Erreur"; } await ClearMessages(); }
    private async Task ClearMessages() { await Task.Delay(3000); successMessage = ""; errorMessage = ""; }
    private List<DoctorDto> GetDemoDoctors() => new() { new DoctorDto { Id = 1, FirstName = "Sarah", LastName = "Ben Ahmed", Speciality = "Cardiologie", Email = "sarah@email.com", IsValidated = true }, new DoctorDto { Id = 2, FirstName = "Mehdi", LastName = "Kacem", Speciality = "Dermatologie", Email = "mehdi@email.com", IsValidated = true } };
    public class DoctorDto { public int Id { get; set; } public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; public string Speciality { get; set; } = ""; public string Email { get; set; } = ""; public bool IsValidated { get; set; } }
    public class CreateDoctorDto { public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; public string Email { get; set; } = ""; public string Speciality { get; set; } = "Médecine Générale"; public string PhoneNumber { get; set; } = ""; public string LicenseNumber { get; set; } = "MED-" + DateTime.Now.Year; }
}