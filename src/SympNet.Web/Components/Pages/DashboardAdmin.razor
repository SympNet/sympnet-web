@page "/dashboard-admin"
@using SympNet.Web.Components.Layout
@layout AdminLayout
@inject NavigationManager Nav
@inject HttpClient Http
@using System.Text.Json

<PageTitle>SympNet — Tableau de Bord Admin</PageTitle>

<style>
    :root { --primary: #0D9488; --success: #10B981; --warning: #F59E0B; --gray: #6B7280; --white: #FFFFFF; --light: #F9FAFB; --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.05); --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.1); --radius-lg: 16px; --radius-xl: 24px; }
    .dashboard-container { max-width: 1400px; margin: 0 auto; }
    .welcome-banner { background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); border-radius: var(--radius-xl); padding: 32px 40px; margin-bottom: 32px; }
    .welcome-banner h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 800; color: white; margin-bottom: 8px; }
    .welcome-date { text-align: right; color: white; }
    .welcome-date .day { font-family: 'Bricolage Grotesque', sans-serif; font-size: 34px; font-weight: 800; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: var(--white); border-radius: var(--radius-lg); padding: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 12px; }
    .stat-icon.teal { background: rgba(13,148,136,0.1); color: #0D9488; }
    .stat-icon.green { background: rgba(16,185,129,0.1); color: #10B981; }
    .stat-icon.orange { background: rgba(245,158,11,0.1); color: #F59E0B; }
    .stat-icon.blue { background: rgba(59,130,246,0.1); color: #3B82F6; }
    .stat-value { font-family: 'Bricolage Grotesque', sans-serif; font-size: 32px; font-weight: 800; color: #1F2937; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: var(--gray); }
    .content-grid { display: grid; grid-template-columns: 1fr 340px; gap: 24px; }
    .card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    .card-header { padding: 16px 20px; border-bottom: 1px solid rgba(13,148,136,0.1); display: flex; justify-content: space-between; align-items: center; }
    .doctor-list { padding: 8px 0; }
    .doctor-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; }
    .doctor-avatar { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488, #14B8A6); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 700; color: white; }
    .speciality-list { padding: 16px 20px; }
    .speciality-item { margin-bottom: 16px; }
    .speciality-bar { height: 6px; background: rgba(13,148,136,0.1); border-radius: 3px; overflow: hidden; }
    .speciality-fill { height: 100%; background: linear-gradient(90deg, #0D9488, #14B8A6); border-radius: 3px; }
    @@media (max-width: 1024px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } .content-grid { grid-template-columns: 1fr; } }
</style>

<div class="dashboard-container">
    <div class="welcome-banner">
        <div style="display: flex; justify-content: space-between;">
            <div><h1>Bonjour, Administrateur 👋</h1><p>Voici l'aperçu de votre plateforme SympNet</p></div>
            <div class="welcome-date"><div class="day">@DateTime.Now.Day</div><div>@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</div></div>
        </div>
    </div>
    <div class="stats-grid">
        <div class="stat-card"><div class="stat-icon teal"><i class="fas fa-user-md"></i></div><div class="stat-value">@stats.TotalDoctors</div><div class="stat-label">Total Médecins</div></div>
        <div class="stat-card"><div class="stat-icon green"><i class="fas fa-check-circle"></i></div><div class="stat-value">@stats.ActiveDoctors</div><div class="stat-label">Médecins Actifs</div></div>
        <div class="stat-card"><div class="stat-icon orange"><i class="fas fa-clock"></i></div><div class="stat-value">@stats.PendingDoctors</div><div class="stat-label">En attente</div></div>
        <div class="stat-card"><div class="stat-icon blue"><i class="fas fa-procedures"></i></div><div class="stat-value">@stats.TotalPatients</div><div class="stat-label">Total Patients</div></div>
    </div>
    <div class="content-grid">
        <div class="card">
            <div class="card-header"><h3><i class="fas fa-user-md"></i> Médecins Récents</h3><button @onclick="GoToDoctors">Voir tout →</button></div>
            <div class="doctor-list">
                @foreach (var d in doctors.TakeLast(5).Reverse())
                {
                    <div class="doctor-item"><div class="doctor-avatar">@d.FirstName[0]@d.LastName[0]</div><div class="doctor-info"><div class="doctor-name">Dr. @d.FirstName @d.LastName</div><div class="doctor-speciality">@d.Speciality</div></div><span class="doctor-status active">Actif</span></div>
                }
            </div>
        </div>
        <div class="card">
            <div class="card-header"><h3><i class="fas fa-chart-pie"></i> Par Spécialité</h3></div>
            <div class="speciality-list">
                @{ var grouped = doctors.GroupBy(d => d.Speciality).OrderByDescending(g => g.Count()).Take(6).ToList(); var maxCount = grouped.Any() ? grouped.Max(g => g.Count()) : 1; }
                @foreach (var g in grouped)
                {
                    <div class="speciality-item"><div class="speciality-header"><span>@g.Key</span><span>@g.Count() dr.</span></div><div class="speciality-bar"><div class="speciality-fill" style="width: @(g.Count() * 100 / maxCount)%"></div></div></div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Role { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }
    
    private List<DoctorDto> doctors = new();
    private StatsDto stats = new();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(Token))
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);
        await LoadData();
    }
    
    private async Task LoadData()
    {
        try
        {
            var docs = await Http.GetFromJsonAsync<List<DoctorDto>>("api/admin/doctors");
            if (docs != null) doctors = docs;
            var s = await Http.GetFromJsonAsync<StatsDto>("api/admin/stats");
            if (s != null) stats = s;
        }
        catch { }
    }
    
    private void GoToDoctors()
    {
        Nav.NavigateTo($"/admin/doctors?token={Token}&role=admin&email={Email}");
    }
    
    public class DoctorDto { public int Id { get; set; } public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; public string Speciality { get; set; } = ""; public bool IsValidated { get; set; } }
    public class StatsDto { public int TotalPatients { get; set; } public int TotalDoctors { get; set; } public int ActiveDoctors { get; set; } public int PendingDoctors { get; set; } }
}